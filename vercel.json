{
  "rewrites": [
    {
      "source": "/doc/",
      "destination": "https://doc.aoshield.cn/"
    },
    {
      "source": "/doc",
      "destination": "https://doc.aoshield.cn/"
    },
    {
      "source": "/doc/aos-desktop/",
      "destination": "https://doc.aoshield.cn/aos-desktop/"
    },
    {
      "source": "/doc/:path*",
      "destination": "https://doc.aoshield.cn/:path*"
    },
    {
      "source": "/api/public/desktop/latest",
      "destination": "https://api.123offer.cn/api/public/desktop/latest"
    }
  ]
}
