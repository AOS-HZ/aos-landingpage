---
import Container from "../components/Container.astro";
import ShieldMark from "../components/ShieldMark.astro";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import {
  CLI_INSTALL_COMMAND,
  DESKTOP_SUPPORT_NOTE,
  DOWNLOAD_PLATFORMS,
} from "../constants/download";
import { DOCS_URL } from "../constants/site";

const defaultPlatform =
  DOWNLOAD_PLATFORMS.find((platform) => platform.enabled !== false) ?? DOWNLOAD_PLATFORMS[0];
const commandDisplayLines = CLI_INSTALL_COMMAND.split(" && ").map((segment, index, segments) =>
  index < segments.length - 1 ? `${segment} &&` : segment
);
---

<Layout
  title="下载 Aegis (AOS Desktop) | AOS"
  description="Aegis (AOS Desktop) 下载页"
  bodyClass="body-plain"
>
  <div class="download-page">
    <Navbar showNavLinks={false} actionButton={{ text: "文档中心", href: DOCS_URL }} />

    <main class="download-main">
      <Container>
        <section class="download-hero" data-download-root>
          <div class="download-hero__headline">
            <div class="download-hero__mark" aria-hidden="true">
              <ShieldMark class="h-12 w-12 text-[var(--color-primary)]" />
            </div>

            <h1 class="download-hero__title">
              下载 <span class="download-hero__title-accent">Aegis</span>
              <span class="download-hero__title-meta">(AOS Desktop)</span>
            </h1>
          </div>

          <div class="download-platforms" role="tablist" aria-label="选择桌面端平台">
            {
              DOWNLOAD_PLATFORMS.map((platform, index) => (
                <button
                  type="button"
                  class:list={[
                    "download-platform",
                    index === 0 && "is-active",
                    platform.enabled === false && "is-disabled",
                  ]}
                  data-platform-trigger
                  data-platform-id={platform.id}
                  data-platform-href={platform.href}
                  data-platform-action={platform.action}
                  aria-disabled={platform.enabled === false ? "true" : "false"}
                  aria-pressed={index === 0 ? "true" : "false"}
                  disabled={platform.enabled === false}
                >
                  {platform.badge && <span class="download-platform__badge">{platform.badge}</span>}
                  <span class="download-platform__icon" aria-hidden="true">
                    {platform.id === "macos" && (
                      <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none">
                        <path d="M15.4 5.25c.5-.62.87-1.48.8-2.35-.77.03-1.72.52-2.27 1.16-.5.58-.93 1.44-.81 2.28.86.07 1.76-.43 2.28-1.09Z" fill="currentColor"></path>
                        <path d="M17.84 12.57c.02-2.26 1.85-3.34 1.94-3.4-1.06-1.55-2.71-1.76-3.29-1.78-1.4-.15-2.74.83-3.45.83-.72 0-1.82-.81-2.98-.79-1.54.02-2.96.9-3.75 2.29-1.61 2.78-.41 6.88 1.15 9.13.76 1.09 1.68 2.32 2.88 2.28 1.16-.05 1.59-.74 2.99-.74 1.41 0 1.79.74 3 .71 1.25-.02 2.03-1.12 2.79-2.21.87-1.28 1.24-2.53 1.26-2.59-.03-.01-2.41-.93-2.54-3.73Z" fill="currentColor"></path>
                      </svg>
                    )}
                    {platform.id === "linux" && (
                      <svg
                        stroke="currentColor"
                        fill="currentColor"
                        stroke-width="0"
                        viewBox="0 0 448 512"
                        class="h-8 w-8 p-0.5"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path d="M220.8 123.3c1 .5 1.8 1.7 3 1.7 1.1 0 2.8-.4 2.9-1.5.2-1.4-1.9-2.3-3.2-2.9-1.7-.7-3.9-1-5.5-.1-.4.2-.8.7-.6 1.1.3 1.3 2.3 1.1 3.4 1.7zm-21.9 1.7c1.2 0 2-1.2 3-1.7 1.1-.6 3.1-.4 3.5-1.6.2-.4-.2-.9-.6-1.1-1.6-.9-3.8-.6-5.5.1-1.3.6-3.4 1.5-3.2 2.9.1 1 1.8 1.5 2.8 1.4zM420 403.8c-3.6-4-5.3-11.6-7.2-19.7-1.8-8.1-3.9-16.8-10.5-22.4-1.3-1.1-2.6-2.1-4-2.9-1.3-.8-2.7-1.5-4.1-2 9.2-27.3 5.6-54.5-3.7-79.1-11.4-30.1-31.3-56.4-46.5-74.4-17.1-21.5-33.7-41.9-33.4-72C311.1 85.4 315.7.1 234.8 0 132.4-.2 158 103.4 156.9 135.2c-1.7 23.4-6.4 41.8-22.5 64.7-18.9 22.5-45.5 58.8-58.1 96.7-6 17.9-8.8 36.1-6.2 53.3-6.5 5.8-11.4 14.7-16.6 20.2-4.2 4.3-10.3 5.9-17 8.3s-14 6-18.5 14.5c-2.1 3.9-2.8 8.1-2.8 12.4 0 3.9.6 7.9 1.2 11.8 1.2 8.1 2.5 15.7.8 20.8-5.2 14.4-5.9 24.4-2.2 31.7 3.8 7.3 11.4 10.5 20.1 12.3 17.3 3.6 40.8 2.7 59.3 12.5 19.8 10.4 39.9 14.1 55.9 10.4 11.6-2.6 21.1-9.6 25.9-20.2 12.5-.1 26.3-5.4 48.3-6.6 14.9-1.2 33.6 5.3 55.1 4.1.6 2.3 1.4 4.6 2.5 6.7v.1c8.3 16.7 23.8 24.3 40.3 23 16.6-1.3 34.1-11 48.3-27.9 13.6-16.4 36-23.2 50.9-32.2 7.4-4.5 13.4-10.1 13.9-18.3.4-8.2-4.4-17.3-15.5-29.7zM223.7 87.3c9.8-22.2 34.2-21.8 44-.4 6.5 14.2 3.6 30.9-4.3 40.4-1.6-.8-5.9-2.6-12.6-4.9 1.1-1.2 3.1-2.7 3.9-4.6 4.8-11.8-.2-27-9.1-27.3-7.3-.5-13.9 10.8-11.8 23-4.1-2-9.4-3.5-13-4.4-1-6.9-.3-14.6 2.9-21.8zM183 75.8c10.1 0 20.8 14.2 19.1 33.5-3.5 1-7.1 2.5-10.2 4.6 1.2-8.9-3.3-20.1-9.6-19.6-8.4.7-9.8 21.2-1.8 28.1 1 .8 1.9-.2-5.9 5.5-15.6-14.6-10.5-52.1 8.4-52.1zm-13.6 60.7c6.2-4.6 13.6-10 14.1-10.5 4.7-4.4 13.5-14.2 27.9-14.2 7.1 0 15.6 2.3 25.9 8.9 6.3 4.1 11.3 4.4 22.6 9.3 8.4 3.5 13.7 9.7 10.5 18.2-2.6 7.1-11 14.4-22.7 18.1-11.1 3.6-19.8 16-38.2 14.9-3.9-.2-7-1-9.6-2.1-8-3.5-12.2-10.4-20-15-8.6-4.8-13.2-10.4-14.7-15.3-1.4-4.9 0-9 4.2-12.3zm3.3 334c-2.7 35.1-43.9 34.4-75.3 18-29.9-15.8-68.6-6.5-76.5-21.9-2.4-4.7-2.4-12.7 2.6-26.4v-.2c2.4-7.6.6-16-.6-23.9-1.2-7.8-1.8-15 .9-20 3.5-6.7 8.5-9.1 14.8-11.3 10.3-3.7 11.8-3.4 19.6-9.9 5.5-5.7 9.5-12.9 14.3-18 5.1-5.5 10-8.1 17.7-6.9 8.1 1.2 15.1 6.8 21.9 16l19.6 35.6c9.5 19.9 43.1 48.4 41 68.9zm-1.4-25.9c-4.1-6.6-9.6-13.6-14.4-19.6 7.1 0 14.2-2.2 16.7-8.9 2.3-6.2 0-14.9-7.4-24.9-13.5-18.2-38.3-32.5-38.3-32.5-13.5-8.4-21.1-18.7-24.6-29.9s-3-23.3-.3-35.2c5.2-22.9 18.6-45.2 27.2-59.2 2.3-1.7.8 3.2-8.7 20.8-8.5 16.1-24.4 53.3-2.6 82.4.6-20.7 5.5-41.8 13.8-61.5 12-27.4 37.3-74.9 39.3-112.7 1.1.8 4.6 3.2 6.2 4.1 4.6 2.7 8.1 6.7 12.6 10.3 12.4 10 28.5 9.2 42.4 1.2 6.2-3.5 11.2-7.5 15.9-9 9.9-3.1 17.8-8.6 22.3-15 7.7 30.4 25.7 74.3 37.2 95.7 6.1 11.4 18.3 35.5 23.6 64.6 3.3-.1 7 .4 10.9 1.4 13.8-35.7-11.7-74.2-23.3-84.9-4.7-4.6-4.9-6.6-2.6-6.5 12.6 11.2 29.2 33.7 35.2 59 2.8 11.6 3.3 23.7.4 35.7 16.4 6.8 35.9 17.9 30.7 34.8-2.2-.1-3.2 0-4.2 0 3.2-10.1-3.9-17.6-22.8-26.1-19.6-8.6-36-8.6-38.3 12.5-12.1 4.2-18.3 14.7-21.4 27.3-2.8 11.2-3.6 24.7-4.4 39.9-.5 7.7-3.6 18-6.8 29-32.1 22.9-76.7 32.9-114.3 7.2zm257.4-11.5c-.9 16.8-41.2 19.9-63.2 46.5-13.2 15.7-29.4 24.4-43.6 25.5s-26.5-4.8-33.7-19.3c-4.7-11.1-2.4-23.1 1.1-36.3 3.7-14.2 9.2-28.8 9.9-40.6.8-15.2 1.7-28.5 4.2-38.7 2.6-10.3 6.6-17.2 13.7-21.1.3-.2.7-.3 1-.5.8 13.2 7.3 26.6 18.8 29.5 12.6 3.3 30.7-7.5 38.4-16.3 9-.3 15.7-.9 22.6 5.1 9.9 8.5 7.1 30.3 17.1 41.6 10.6 11.6 14 19.5 13.7 24.6zM173.3 148.7c2 1.9 4.7 4.5 8 7.1 6.6 5.2 15.8 10.6 27.3 10.6 11.6 0 22.5-5.9 31.8-10.8 4.9-2.6 10.9-7 14.8-10.4s5.9-6.3 3.1-6.6-2.6 2.6-6 5.1c-4.4 3.2-9.7 7.4-13.9 9.8-7.4 4.2-19.5 10.2-29.9 10.2s-18.7-4.8-24.9-9.7c-3.1-2.5-5.7-5-7.7-6.9-1.5-1.4-1.9-4.6-4.3-4.9-1.4-.1-1.8 3.7 1.7 6.5z"></path>
                      </svg>
                    )}
                    {platform.id === "windows" && (
                      <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none">
                        <path d="M4.75 6.5 11.5 5v6.5H4.75V6.5Z" fill="currentColor"></path>
                        <path d="M12.5 4.8 19.25 3.5v8H12.5V4.8Z" fill="currentColor"></path>
                        <path d="M4.75 12.5h6.75V19l-6.75-1.35V12.5Z" fill="currentColor"></path>
                        <path d="M12.5 12.5h6.75v7.95L12.5 19V12.5Z" fill="currentColor"></path>
                      </svg>
                    )}
                  </span>
                  <span class="download-platform__label">{platform.label}</span>
                </button>
              ))
            }
          </div>

          <div class="download-command" aria-label="CLI 安装命令">
            <code class="download-command__text" data-command-text data-command-value={CLI_INSTALL_COMMAND}>
              {commandDisplayLines.map((line) => (
                <span class="download-command__line">{line}</span>
              ))}
            </code>
            <button type="button" class="download-command__copy" data-copy-command>
              <span data-copy-label>复制</span>
              <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4" fill="none">
                <rect x="6" y="6" width="10" height="10" rx="2" stroke="currentColor" stroke-width="1.5"></rect>
                <path d="M4 12V6a2 2 0 0 1 2-2h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
              </svg>
            </button>
          </div>
          <p class="download-hero__or">or</p>

          <a href={defaultPlatform.href} class="download-primary" data-platform-primary>
            {defaultPlatform.action}
          </a>

          <p class="download-hero__note" data-platform-note>{DESKTOP_SUPPORT_NOTE}</p>
        </section>
      </Container>
    </main>

    <Footer compact={true} />
  </div>

  <script>
    (() => {
      const root = document.querySelector("[data-download-root]");
      if (!root) return;

      const triggers = Array.from(root.querySelectorAll("[data-platform-trigger]"));
      const primary = root.querySelector("[data-platform-primary]");
      const note = root.querySelector("[data-platform-note]");
      const copyButton = root.querySelector("[data-copy-command]");
      const copyLabel = root.querySelector("[data-copy-label]");
      const commandText = root.querySelector("[data-command-text]");
      const fallbackNote = note?.textContent ?? "";

      const setActivePlatform = (platformId) => {
        const activeTrigger = triggers.find((trigger) => trigger.dataset.platformId === platformId) ?? triggers[0];
        if (!activeTrigger) return;

        if (activeTrigger.getAttribute("aria-disabled") === "true") {
          return;
        }

        triggers.forEach((trigger) => {
          const isActive = trigger === activeTrigger;
          trigger.classList.toggle("is-active", isActive);
          trigger.setAttribute("aria-pressed", isActive ? "true" : "false");
        });

        if (primary) {
          primary.setAttribute("href", activeTrigger.dataset.platformHref ?? "/download");
          primary.textContent = activeTrigger.dataset.platformAction ?? "查看安装说明";
        }

        if (note) {
          note.textContent = fallbackNote;
        }
      };

      triggers.forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const platformId = trigger.dataset.platformId;
          if (platformId) setActivePlatform(platformId);
        });
      });

      const requestedPlatform = new URLSearchParams(window.location.search).get("platform");
      const hasRequestedPlatform = triggers.some((trigger) => trigger.dataset.platformId === requestedPlatform);
      setActivePlatform(hasRequestedPlatform ? requestedPlatform : "macos");

      if (!copyButton || !copyLabel || !commandText) return;

      let copyTimeoutId = 0;
      copyButton.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(
            commandText.dataset.commandValue?.trim() ?? commandText.textContent?.replace(/\s+/g, " ").trim() ?? ""
          );
          copyLabel.textContent = "已复制";
        } catch {
          copyLabel.textContent = "失败";
        }

        window.clearTimeout(copyTimeoutId);
        copyTimeoutId = window.setTimeout(() => {
          copyLabel.textContent = "复制";
        }, 1800);
      });
    })();
  </script>
</Layout>

<style>
  .download-page {
    display: flex;
    min-height: 100vh;
    flex-direction: column;
    background: #ffffff;
    color: var(--color-ink);
  }

  .download-main {
    flex: 1 1 auto;
  }

  .download-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 0 88px;
    text-align: center;
  }

  .download-hero__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4.5vw, 3.75rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.06em;
    color: #111111;
    text-wrap: balance;
  }

  .download-hero__headline {
    display: inline-flex;
    align-items: center;
    gap: 18px;
  }

  .download-hero__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 22px;
    background: #f7f9fc;
    box-shadow: inset 0 0 0 1px rgba(24, 29, 38, 0.06);
    flex-shrink: 0;
  }

  .download-hero__title-accent {
    color: var(--color-primary);
  }

  .download-hero__title-meta {
    white-space: nowrap;
  }

  .download-platforms {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 42px;
  }

  .download-platform {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 10px;
    min-width: 132px;
    border: 0;
    border-radius: 18px;
    background: transparent;
    padding: 18px 16px;
    color: #1f1f23;
    transition: background-color 0.2s ease, transform 0.2s ease, opacity 0.2s ease;
  }

  .download-platform:hover {
    background: #f7f7f8;
  }

  .download-platform.is-active {
    background: #f3f3f4;
  }

  .download-platform.is-disabled {
    cursor: not-allowed;
    opacity: 0.72;
  }

  .download-platform.is-disabled:hover {
    background: transparent;
    transform: none;
  }

  .download-platform__badge {
    position: absolute;
    top: 8px;
    right: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 22px;
    border-radius: 999px;
    background: #f1f1f2;
    padding: 0 8px;
    font-size: 11px;
    font-weight: 600;
    line-height: 1;
    color: #7a7a80;
  }

  .download-platform__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
  }

  .download-platform__label {
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.2;
  }

  .download-command {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: min(100%, 580px);
    margin-top: 40px;
    border-radius: 18px;
    background: #f5f5f5;
    padding: 14px 16px 14px 20px;
  }

  .download-command__text {
    display: block;
    flex: 1 1 auto;
    min-width: 0;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.5;
    white-space: normal;
    color: #171717;
  }

  .download-command__line {
    display: block;
    white-space: nowrap;
  }

  .download-command__copy {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    border-radius: 999px;
    background: #ececec;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #303036;
    transition: background-color 0.2s ease;
  }

  .download-command__copy:hover {
    background: #e2e2e2;
  }

  .download-hero__or,
  .download-hero__note {
    margin: 0;
    color: #66666d;
  }

  .download-hero__or {
    margin-top: 18px;
    font-size: 1rem;
  }

  .download-primary {
    display: inline-flex;
    min-height: 58px;
    align-items: center;
    justify-content: center;
    margin-top: 16px;
    border-radius: 999px;
    background: #232323;
    padding: 0 34px;
    font-size: 1.08rem;
    font-weight: 500;
    color: #ffffff;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .download-primary:hover {
    background: #191919;
    transform: translateY(-1px);
  }

  .download-hero__note {
    margin-top: 16px;
    max-width: 30rem;
    font-size: 0.94rem;
    line-height: 1.65;
    text-wrap: balance;
  }



  @media (max-width: 720px) {

    .download-hero {
      padding: 48px 0 64px;
    }

    .download-hero__headline {
      gap: 14px;
    }

    .download-hero__mark {
      width: 60px;
      height: 60px;
      border-radius: 18px;
    }

    .download-platforms {
      width: 100%;
      gap: 8px;
    }

    .download-platform {
      min-width: 0;
      flex: 1 1 30%;
    }

    .download-command {
      flex-direction: column;
      align-items: stretch;
      margin-top: 36px;
      padding: 16px;
    }

    .download-command__copy {
      align-self: flex-end;
    }
  }
</style>
