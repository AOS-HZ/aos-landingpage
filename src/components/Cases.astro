---
import Container from "./Container.astro";

const cases = [
  {
    sector: "Fintech",
    company: "头部金融科技团队",
    quote: "上线前发现 47 个高危 Agent 风险。",
    accent: "background: rgba(27, 97, 201, 0.1); color: var(--color-primary);",
    metrics: ["12,000+ 次异常调用被阻断", "安全审计效率提升 80%"],
  },
  {
    sector: "Manufacturing",
    company: "跨国制造集团",
    quote: "第一次看清了第三方 MCP 风险。",
    accent: "background: rgba(122, 61, 255, 0.12); color: var(--color-purple);",
    metrics: ["23 个高风险 MCP 被发现", "覆盖全球 5 个研发中心"],
  },
  {
    sector: "Healthcare",
    company: "互联网医疗平台",
    quote: "顺利通过监管审查，合规周期明显缩短。",
    accent: "background: rgba(255, 107, 0, 0.12); color: var(--color-orange);",
    metrics: ["100% 关键操作可追溯", "合规审查时间减少 60%"],
  },
];
---

<section id="customers" class="relative pt-8 pb-10 lg:pt-10 lg:pb-12">
  <Container>
    <div class="grid gap-4 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)] lg:items-end">
      <div>
        <div class="eyebrow">Customer Stories</div>
        <h2 class="section-title mt-4">客户怎么落地</h2>
      </div>
      <p class="section-copy copy-measure lg:justify-self-end">
        三类团队，同一个结果：先看见，再收住风险。
      </p>
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {
        cases.map((item) => (
          <article class="surface-card flex h-full flex-col p-6">
            <span class="accent-chip self-start" style={item.accent}>{item.sector}</span>
            <blockquote class="mt-5 max-w-[13ch] text-balance font-display text-[1.35rem] font-medium leading-[1.25] tracking-[0.04px] text-[var(--color-ink)]">
              “{item.quote}”
            </blockquote>

            <div class="mt-4 text-sm font-medium tracking-[0.08px] text-[var(--color-gray-500)]">
              {item.company}
            </div>

            <div class="mt-6 space-y-3">
              {item.metrics.map((metric) => (
                <div class="flex items-start gap-3 text-sm leading-6 tracking-[0.08px] text-[var(--color-gray-700)]">
                  <span class="mt-2 h-2.5 w-2.5 rounded-[2px] bg-[var(--color-primary)]"></span>
                  <span>{metric}</span>
                </div>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>
