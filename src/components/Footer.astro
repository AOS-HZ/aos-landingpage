---
import Container from "./Container.astro";
import ShieldMark from "./ShieldMark.astro";

const currentYear = new Date().getFullYear();

const footerLinks = [
  { name: "产品功能", href: "#features" },
  { name: "技术架构", href: "#architecture" },
  { name: "文档中心", href: "/docs/" },
  { name: "Quick Start", href: "/docs/aos-desktop/quick-start/" },
];
---

<footer class="border-t border-[var(--color-border)] py-12 sm:py-16">
  <Container>
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.9fr)]">
      <div class="max-w-md">
        <a href="/" class="flex items-center gap-3">
          <ShieldMark class="h-9 w-9 text-[var(--color-primary)]" />
          <div>
            <div class="font-display text-[1.2rem] font-semibold leading-none tracking-[0.04px] text-[var(--color-ink)]">
              AOS
            </div>
            <div class="mt-1 text-[10px] font-medium uppercase tracking-[0.9px] text-[var(--color-gray-300)]">
              Focus on agent runtime security
            </div>
          </div>
        </a>

        <p class="mt-5 text-sm leading-6 tracking-[0.08px] text-[var(--color-gray-500)]">
          守护 Agent 可信运行，让安全边界重新可运营。
        </p>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        {footerLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-[12px] border border-[var(--color-border)] px-4 py-3 text-sm leading-6 tracking-[0.08px] text-[var(--color-gray-500)] transition-colors hover:text-[var(--color-ink)]"
          >
            {link.name}
          </a>
        ))}
      </div>
    </div>

    <div class="mt-10 border-t border-[var(--color-border)] pt-6 text-sm tracking-[0.08px] text-[var(--color-gray-500)]">
      © {currentYear} AOS. All rights reserved.
    </div>
  </Container>
</footer>
