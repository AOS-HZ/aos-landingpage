---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "primary" | "secondary" | "outline" | "ghost";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "min-h-[48px] px-6 text-base",
  md: "min-h-[42px] px-4 text-[15px]",
};

const styles = {
  primary:
    "border border-[var(--color-primary)] bg-[var(--color-primary)] text-white hover:border-[var(--color-primary-deep)] hover:bg-[var(--color-primary-deep)]",
  secondary:
    "border border-[var(--color-ink)] bg-[var(--color-ink)] text-white hover:border-[var(--color-gray-800)] hover:bg-[var(--color-gray-800)]",
  outline:
    "border border-[var(--color-border)] bg-white text-[var(--color-ink)] hover:border-[var(--color-primary)] hover:bg-[var(--theme_surface-spotlight)]",
  ghost:
    "border border-transparent bg-transparent text-[var(--color-ink)] hover:border-[var(--color-border)] hover:bg-white",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "button-lift inline-flex items-center justify-center gap-3 rounded-[12px] font-medium leading-[1.3] tracking-[0.08px] shadow-cascade transition-all duration-200 active:translate-y-px",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
>
  <slot />
</a>
