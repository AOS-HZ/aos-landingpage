---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "primary" | "secondary" | "outline" | "ghost";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-6 py-3 text-base",
  md: "px-4 py-2 text-sm",
};

const styles = {
  primary: "bg-primary text-[#020617] font-semibold hover:bg-primary/90 shadow-[0_0_15px_rgba(0,212,170,0.3)] hover:shadow-[0_0_25px_rgba(0,212,170,0.5)]",
  secondary: "bg-secondary text-white font-medium hover:bg-secondary/90 shadow-lg shadow-blue-500/20",
  outline: "border border-white/20 bg-transparent text-white hover:bg-white/5",
  ghost: "bg-transparent text-text-muted hover:text-white hover:bg-white/5",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "inline-flex items-center justify-center rounded-full transition-all duration-300 active:scale-95",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
>
  <slot />
</a>
