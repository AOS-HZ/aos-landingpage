---
import Container from "./Container.astro";
import Link from "./ui/Link.astro";
import { DOCS_URL } from "../constants/site";

const heroSlides = [
  {
    title: "自动标记高权限 Agent、异常 MCP 调用与运行时慢工具",
    eyebrow: "Runtime Center",
    thumb: "运行时监控",
    image: "/assets/activity-monitor.png",
    alt: "AOS runtime monitoring dashboard",
    leftStatus: "28 个活跃会话在线",
    rightStatus: "已拦截 39 次异常调用",
  },
  {
    title: "统一盘点桌面端、CLI 与工作流里的 Agent 资产",
    eyebrow: "Inventory Console",
    thumb: "资产发现",
    image: "/assets/dashboard.png",
    alt: "AOS asset inventory dashboard",
    leftStatus: "25 个环境已纳入统一面板",
    rightStatus: "桌面端与 CLI 来源已同步",
  },
  {
    title: "识别 skills 与 MCP 来源，提前发现第三方能力风险",
    eyebrow: "Skills Audit",
    thumb: "第三方扫描",
    image: "/assets/skills-management.png",
    alt: "AOS skills management dashboard",
    leftStatus: "8 项本地 skills 已完成扫描",
    rightStatus: "高风险来源可直接进入隔离区",
  },
  {
    title: "高风险能力可隔离、恢复或删除，整个过程都有留痕",
    eyebrow: "Quarantine Zone",
    thumb: "权限治理",
    image: "/assets/quarantine-zone.png",
    alt: "AOS quarantine zone dashboard",
    leftStatus: "高风险能力已进入隔离流程",
    rightStatus: "恢复与删除动作全程可追溯",
  },
];

---

<Container>
  <main class="relative pb-10 pt-10 lg:pb-16 lg:pt-14">
    <div class="mx-auto max-w-[900px] text-center animate-[var(--animate-rise-in)]">
      <div class="eyebrow hero-eyebrow justify-center">Agent runtime governance</div>
      <h1 class="hero-title mx-auto mt-6 max-w-[8.2em] font-display text-[clamp(2.8rem,5.2vw,4.95rem)] font-medium leading-[0.96] tracking-[-0.06em] text-[var(--color-ink)]">
        <span class="block">在一个面板里</span>
        <span class="block">
          看清 <span class="text-[var(--color-primary)]">Agent</span> 风险
        </span>
      </h1>
      <p class="copy-measure copy-measure--center mt-6 text-[1.02rem] leading-[1.72] tracking-[0.01em] text-[var(--color-gray-500)] sm:text-[1.1rem]">
        统一发现资产、收紧默认权限、监控运行时行为，在高风险动作发生前完成扫描与拦截。
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Link href="#cta" style="secondary" class="w-full rounded-[16px] px-8 shadow-none sm:w-auto">
          开始体验
        </Link>
        <Link href={DOCS_URL} size="lg" style="outline" class="w-full rounded-[16px] px-8 shadow-none sm:w-auto">
          阅读文档
        </Link>
      </div>
    </div>

    <div class="hero-stage relative mx-auto mt-10 max-w-[1240px] animate-[var(--animate-rise-in)] px-4 pb-4 pt-8 sm:px-6 sm:pb-6 sm:pt-10 lg:mt-12 lg:px-10 lg:pb-10 lg:pt-14" style="animation-delay: 0.12s;">
      <div class="hero-stage__halo"></div>

      <div class="hero-stage__command mx-auto flex max-w-[760px] items-center justify-between gap-4 rounded-[24px] border border-white/80 bg-white/92 px-5 py-4 shadow-[0_20px_60px_rgba(232,88,164,0.18)] backdrop-blur lg:px-8 lg:py-5">
        <div id="hero-command-title" class="text-left text-[1rem] font-medium leading-[1.35] tracking-[-0.02em] text-[var(--color-ink)] sm:text-[1.22rem]">
          {heroSlides[0].title}
        </div>
        <button
          type="button"
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-[var(--color-ink)] text-white transition-transform duration-300 hover:translate-x-0.5"
          aria-label="下一张"
          data-hero-next
        >
          <svg aria-hidden="true" viewBox="0 0 20 20" class="h-5 w-5" fill="none">
            <path d="M4.75 10h10.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            <path d="M10.5 4.75 15.75 10l-5.25 5.25" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
      </div>

      <div class="relative mt-6 overflow-hidden rounded-[30px] border border-white/70 bg-white/96 p-3 shadow-[0_35px_90px_rgba(37,79,173,0.16)] sm:mt-8 sm:rounded-[34px] sm:p-4 lg:p-5" data-hero-rotator>
        <div class="mb-4 flex items-center justify-between px-1 sm:px-2">
          <div class="flex gap-2">
            <span class="h-3 w-3 rounded-full bg-[var(--color-red)]"></span>
            <span class="h-3 w-3 rounded-full bg-[var(--color-yellow)]"></span>
            <span class="h-3 w-3 rounded-full bg-[var(--color-green)]"></span>
          </div>
          <div id="hero-console-title" class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--color-gray-300)]">
            {heroSlides[0].eyebrow}
          </div>
        </div>

        <div class="hero-carousel lg:grid lg:grid-cols-[minmax(0,1fr)_156px] lg:gap-4">
          <div class="hero-carousel__viewport">
            <div class="hero-carousel__track" data-hero-track style="--hero-active-index: 0;">
              {
                heroSlides.map((slide, index) => (
                  <figure class:list={["hero-carousel__panel", index === 0 && "is-active"]} data-hero-panel data-hero-index={index}>
                    <img
                      src={slide.image}
                      alt={slide.alt}
                      class="hero-preview-image"
                    />
                  </figure>
                ))
              }
            </div>
          </div>

          <div class="hero-carousel__thumbs">
            {
              heroSlides.map((slide, index) => (
                <button
                  type="button"
                  class:list={["hero-carousel__thumb", index === 0 && "is-active"]}
                  data-hero-trigger
                  data-hero-index={index}
                  data-command-title={slide.title}
                  data-console-title={slide.eyebrow}
                  data-left-status={slide.leftStatus}
                  data-right-status={slide.rightStatus}
                  aria-label={slide.thumb}
                  aria-pressed={index === 0 ? "true" : "false"}
                >
                  <span class="hero-carousel__thumb-media">
                    <img src={slide.image} alt="" />
                  </span>
                  <span class="hero-carousel__thumb-copy">
                    <span class="hero-carousel__thumb-number">0{index + 1}</span>
                    <span class="hero-carousel__thumb-title">{slide.thumb}</span>
                  </span>
                </button>
              ))
            }
          </div>
        </div>

        <div class="hero-stage__status left-4 top-6 hidden sm:flex lg:left-6 lg:top-8">
          <span class="h-2.5 w-2.5 rounded-full bg-[#2fb469]"></span>
          <span id="hero-status-left">{heroSlides[0].leftStatus}</span>
        </div>

        <div class="hero-stage__status hero-stage__status--right right-4 bottom-6 hidden sm:flex lg:right-6 lg:bottom-8">
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-primary)]"></span>
          <span id="hero-status-right">{heroSlides[0].rightStatus}</span>
        </div>
      </div>
    </div>
  </main>
</Container>

<style>
  .hero-title {
    text-wrap: balance;
  }

  .hero-eyebrow::before {
    width: 7px;
    height: 7px;
    border-radius: 999px;
  }

  .hero-stage {
    overflow: hidden;
    border: 1px solid rgba(240, 188, 219, 0.8);
    border-radius: 40px;
    background:
      linear-gradient(180deg, rgba(255, 236, 246, 0.96) 0%, rgba(250, 239, 255, 0.92) 54%, rgba(244, 248, 255, 0.98) 100%);
    box-shadow:
      0 28px 80px rgba(232, 88, 164, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  .hero-stage__halo {
    position: absolute;
    inset: 10% 14% auto;
    height: 220px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(255, 170, 217, 0.58) 0%, rgba(255, 215, 239, 0.22) 46%, rgba(255, 255, 255, 0) 78%);
    filter: blur(18px);
    pointer-events: none;
  }

  .hero-stage__status {
    position: absolute;
    align-items: center;
    gap: 10px;
    border: 1px solid rgba(24, 29, 38, 0.08);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-ink);
    box-shadow: 0 18px 45px rgba(31, 41, 55, 0.1);
    backdrop-filter: blur(12px);
  }

  .hero-stage__status--right {
    box-shadow: 0 20px 50px rgba(37, 79, 173, 0.14);
  }

  .hero-carousel {
    position: relative;
    align-items: stretch;
  }

  .hero-carousel__viewport {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(24, 29, 38, 0.06);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82) 0%, rgba(248, 250, 255, 1) 100%);
  }

  .hero-carousel__viewport::before,
  .hero-carousel__viewport::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    z-index: 2;
    height: 56px;
    pointer-events: none;
  }

  .hero-carousel__viewport::before {
    top: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0) 100%);
  }

  .hero-carousel__viewport::after {
    bottom: 0;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.86) 100%);
  }

  .hero-carousel__track {
    display: flex;
    height: clamp(320px, 56vw, 760px);
    flex-direction: column;
    transform: translateY(calc(var(--hero-active-index, 0) * -100%));
    transition: transform 820ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .hero-carousel__panel {
    position: relative;
    flex: 0 0 100%;
    min-height: 0;
    opacity: 0.55;
    transform: scale(0.98);
    transition:
      opacity 0.6s ease,
      transform 0.82s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-carousel__panel.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .hero-preview-image {
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: top center;
    transform: scale(1.015);
    transition: transform 1s ease;
  }

  .hero-carousel__panel.is-active .hero-preview-image {
    transform: scale(1);
  }

  .hero-carousel__thumbs {
    margin-top: 16px;
    display: grid;
    gap: 10px;
  }

  .hero-carousel__thumb {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid rgba(24, 29, 38, 0.08);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.72);
    padding: 10px;
    text-align: left;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      background-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .hero-carousel__thumb:hover {
    transform: translateX(-2px);
    border-color: rgba(24, 29, 38, 0.14);
  }

  .hero-carousel__thumb.is-active {
    border-color: rgba(27, 97, 201, 0.16);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 18px 38px rgba(27, 97, 201, 0.08);
    transform: translateX(-4px);
  }

  .hero-carousel__thumb-media {
    display: block;
    width: 56px;
    height: 56px;
    overflow: hidden;
    border: 1px solid rgba(24, 29, 38, 0.08);
    border-radius: 14px;
    background: white;
    flex-shrink: 0;
  }

  .hero-carousel__thumb-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .hero-carousel__thumb-copy {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  .hero-carousel__thumb-number {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-gray-300);
  }

  .hero-carousel__thumb-title {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }

  @media (min-width: 1024px) {
    .hero-stage__status--right {
      right: 188px;
    }

    .hero-carousel__thumbs {
      margin-top: 0;
    }
  }

  @media (max-width: 639px) {
    .hero-title {
      max-width: 6.8em;
      font-size: clamp(2.45rem, 13vw, 3.45rem);
    }

    .hero-stage {
      border-radius: 28px;
    }

    .hero-carousel__track {
      height: 320px;
    }

    .hero-carousel__thumbs {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-carousel__thumb {
      padding: 8px;
    }

    .hero-carousel__thumb-media {
      width: 48px;
      height: 48px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const rotator = document.querySelector("[data-hero-rotator]");
    if (!rotator) return;

    const track = rotator.querySelector("[data-hero-track]");
    const panels = Array.from(rotator.querySelectorAll("[data-hero-panel]"));
    const triggers = Array.from(rotator.querySelectorAll("[data-hero-trigger]"));
    const nextButton = document.querySelector("[data-hero-next]");
    const commandTitle = document.getElementById("hero-command-title");
    const consoleTitle = document.getElementById("hero-console-title");
    const leftStatus = document.getElementById("hero-status-left");
    const rightStatus = document.getElementById("hero-status-right");
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let activeIndex = 0;
    let timerId = 0;

    const render = (index) => {
      activeIndex = index;

      if (track) {
        track.style.setProperty("--hero-active-index", String(index));
      }

      panels.forEach((panel, panelIndex) => {
        panel.classList.toggle("is-active", panelIndex === index);
      });

      triggers.forEach((trigger, triggerIndex) => {
        const isActive = triggerIndex === index;
        trigger.classList.toggle("is-active", isActive);
        trigger.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      const activeTrigger = triggers[index];
      if (!activeTrigger) return;

      if (commandTitle) commandTitle.textContent = activeTrigger.getAttribute("data-command-title") ?? "";
      if (consoleTitle) consoleTitle.textContent = activeTrigger.getAttribute("data-console-title") ?? "";
      if (leftStatus) leftStatus.textContent = activeTrigger.getAttribute("data-left-status") ?? "";
      if (rightStatus) rightStatus.textContent = activeTrigger.getAttribute("data-right-status") ?? "";
    };

    const goNext = () => {
      render((activeIndex + 1) % triggers.length);
    };

    const stopAutoPlay = () => {
      if (timerId) window.clearInterval(timerId);
    };

    const startAutoPlay = () => {
      stopAutoPlay();
      if (prefersReducedMotion || triggers.length <= 1) return;
      timerId = window.setInterval(goNext, 4200);
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener("click", () => {
        render(index);
        startAutoPlay();
      });
    });

    if (nextButton) {
      nextButton.addEventListener("click", () => {
        goNext();
        startAutoPlay();
      });
    }

    rotator.addEventListener("mouseenter", stopAutoPlay);
    rotator.addEventListener("mouseleave", startAutoPlay);
    rotator.addEventListener("focusin", stopAutoPlay);
    rotator.addEventListener("focusout", startAutoPlay);

    render(0);
    startAutoPlay();
  });
</script>
