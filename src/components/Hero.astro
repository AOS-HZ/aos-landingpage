---
import Container from "./Container.astro";
import Link from "./ui/Link.astro";

const capabilityItems = [
  {
    title: "资产发现",
    body: "统一盘点桌面端、CLI 与工作流里的 Agent。",
  },
  {
    title: "权限治理",
    body: "按任务上下文收紧 scope 与默认权限。",
  },
  {
    title: "运行时策略",
    body: "在 prompt、tool call 和 response 之间拦下高危动作。",
  },
];

---

<Container>
  <main class="relative grid gap-10 pb-12 pt-[7rem] lg:grid-cols-[minmax(0,0.84fr)_minmax(0,1fr)] lg:items-center lg:gap-12 lg:pb-16 lg:pt-28">
    <div class="relative z-10 max-w-[36rem] animate-[var(--animate-rise-in)]">
      <div class="eyebrow">Focus on agent runtime security</div>
      <h1 class="mt-6 max-w-[13.5ch] font-display text-[clamp(2.6rem,4.7vw,4rem)] font-normal leading-[1.02] tracking-[-0.04em] text-[var(--color-ink)]">
        <span class="block">在一个面板里</span>
        <span class="mt-2 block">
          看清 <span class="font-black text-[var(--color-primary)]">Agent</span> 风险
        </span>
      </h1>
      <p class="mt-6 max-w-[34rem] text-[1.0625rem] leading-[1.72] tracking-[0.16px] text-[var(--color-gray-500)]">
        先看到有哪些 Agent、用了哪些权限和 MCP，再决定哪些风险要扫描、哪些动作要拦。
      </p>

      <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
        <Link href="/docs/aos-desktop/quick-start/" style="primary" class="w-full gap-2 sm:w-auto">
          <span class="inline-flex h-4 w-4 shrink-0 items-center justify-center">
            <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4" fill="none">
              <path d="M4.75 10h10.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              <path d="M10.5 4.75 15.75 10l-5.25 5.25" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <span>立即试用</span>
        </Link>
        <Link href="/docs/" size="lg" style="outline" class="w-full gap-2 sm:w-auto">
          <span class="inline-flex h-4 w-4 shrink-0 items-center justify-center">
            <svg aria-hidden="true" viewBox="0 0 20 20" class="h-4 w-4" fill="none">
              <path d="M6.25 4.75h7.5A1.5 1.5 0 0 1 15.25 6.25v8.5a.5.5 0 0 1-.5.5H7.25A2.5 2.5 0 0 0 4.75 17V6.25a1.5 1.5 0 0 1 1.5-1.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
              <path d="M7.75 8h4.75M7.75 10.75h4.75" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
            </svg>
          </span>
          <span>阅读文档</span>
        </Link>
      </div>

      <div class="mt-8 grid gap-3">
        {
          capabilityItems.map((item) => (
            <div class="flex items-start gap-3 rounded-[18px] border border-[var(--color-border)] bg-white/88 px-4 py-3">
              <span class="mt-2 h-2.5 w-2.5 shrink-0 rounded-[2px] bg-[var(--color-primary)]"></span>
              <div>
                <div class="text-sm font-semibold leading-6 tracking-[0.08px] text-[var(--color-ink)]">{item.title}</div>
                <div class="text-sm leading-6 tracking-[0.1px] text-[var(--color-gray-500)]">{item.body}</div>
              </div>
            </div>
          ))
        }
      </div>

    </div>

    <div class="relative z-10 animate-[var(--animate-rise-in)]" style="animation-delay: 0.12s;">
      <div class="surface-card relative ml-auto max-w-[39rem] overflow-hidden p-3 sm:p-4 lg:p-5">
        <div class="mb-3 flex items-center justify-between px-1 sm:px-2">
          <div class="flex gap-2">
            <span class="h-3 w-3 rounded-full bg-[var(--color-red)]"></span>
            <span class="h-3 w-3 rounded-full bg-[var(--color-yellow)]"></span>
            <span class="h-3 w-3 rounded-full bg-[var(--color-green)]"></span>
          </div>
          <div class="text-[11px] font-semibold uppercase tracking-[1px] text-[var(--color-gray-300)]">
            Product Preview
          </div>
        </div>

        <div class="overflow-hidden rounded-[22px] border border-[var(--color-border)] bg-white">
          <img
            src="/assets/dashboard- preview.png"
            alt="Agents of Shield security dashboard"
            class="hero-preview-image h-[360px] w-full object-cover object-center sm:h-[420px] lg:h-[500px]"
          />
        </div>
      </div>
    </div>
  </main>
</Container>

<style>
  .hero-preview-image {
    transform: scale(1.08);
    transform-origin: center;
  }
</style>
