---
import Container from "./Container.astro";
import Link from "./ui/Link.astro";
---

<Container>
  <main class="relative grid place-items-center gap-12 pt-32 pb-16 md:pt-40 md:pb-32 lg:grid-cols-2">
    <!-- Animated background glow behind text -->
    <div class="absolute top-20 left-10 -z-10 h-72 w-72 rounded-full bg-blue-400/20 mix-blend-multiply blur-3xl filter animate-float"></div>
    <div class="absolute top-40 right-1/4 -z-10 h-72 w-72 rounded-full bg-indigo-300/20 mix-blend-multiply blur-3xl filter animate-float" style="animation-delay: 2s;"></div>

    <div class="order-1 w-full lg:order-1">
      <div class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-blue-50/50 px-3 py-1.5 text-xs font-medium text-blue-700 backdrop-blur-sm mb-6 shadow-sm">
        <span class="flex h-2 w-2 rounded-full bg-blue-600 animate-pulse"></span>
        Agents-of-Shield v0.2.0 Released
      </div>
      <h1 class="max-w-[12ch] font-display text-5xl font-extrabold tracking-tight text-slate-900 md:text-6xl xl:text-[4.5rem] leading-[1.05]">
        Local agent security, <span class="bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">made readable.</span>
      </h1>
      <p class="mt-6 max-w-xl text-lg text-slate-600 leading-relaxed">
        面向本地 AI Agent 生态的桌面安全控制台。它自动发现、扫描并监控
        <strong class="font-medium text-slate-900">Skills、MCP Servers、Tools</strong>，把分散的风险转化为一目了然的防护链路。
      </p>
      
      <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
        <Link href="#launch" class="flex items-center justify-center shadow-lg shadow-blue-500/20 hover:shadow-blue-500/30 hover:-translate-y-0.5 transition-all w-full sm:w-auto">
          Book Demo
        </Link>
        <Link
          size="lg"
          style="outline"
          href="#screens"
          class="flex items-center justify-center bg-white/50 backdrop-blur-sm hover:bg-white/80 transition-all border-slate-200 hover:border-slate-300 w-full sm:w-auto"
        >
          View Screens
        </Link>
      </div>

      <ul class="mt-12 space-y-4 text-sm font-medium leading-7 text-slate-500 border-t border-slate-200/60 pt-8">
        <li class="flex items-start gap-3">
          <svg class="h-5 w-5 shrink-0 text-blue-500 mt-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
          <span class="text-slate-700">重点回答组件被安装后、具备的能力与可能的风险。</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="h-5 w-5 shrink-0 text-blue-500 mt-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
          <span class="text-slate-700">从发现到隔离一站搞定，保护你的本地安全基线。</span>
        </li>
      </ul>
    </div>

    <div class="order-2 w-full lg:order-2 relative animate-fade-in-up" style="animation-delay: 0.1s;">
      <!-- Glowing background behind image -->
      <div class="absolute -inset-1 rounded-[2.5rem] bg-gradient-to-tr from-blue-100 to-indigo-50 opacity-50 blur-2xl"></div>
      
      <!-- The mockup container -->
      <div class="relative rounded-2xl border border-slate-200/60 bg-white/70 backdrop-blur-xl p-2 shadow-2xl shadow-slate-900/5 ring-1 ring-slate-900/5 overflow-hidden animate-float">
        <!-- Browser / Mac Top Bar -->
        <div class="flex items-center gap-2 px-3 py-2.5">
          <div class="flex gap-1.5">
            <div class="h-3 w-3 rounded-full bg-red-400 border border-red-500/20"></div>
            <div class="h-3 w-3 rounded-full bg-amber-400 border border-amber-500/20"></div>
            <div class="h-3 w-3 rounded-full bg-green-400 border border-green-500/20"></div>
          </div>
        </div>
        
        <!-- Image wrapper -->
        <div class="rounded-xl overflow-hidden border border-slate-100 bg-slate-50 shadow-inner">
          <img
            src="/assets/dashboard.png"
            alt="Agents-of-Shield Dashboard"
            class="w-full object-cover rounded-xl"
          />
        </div>
      </div>
    </div>
  </main>
</Container>
