---
import Container from "./Container.astro";
import Link from "./ui/Link.astro";
---

<Container>
  <main class="relative grid place-items-center gap-12 pt-32 pb-16 md:pt-40 md:pb-32 lg:grid-cols-2 min-h-[90vh]">
    <!-- Animated background glow behind text -->
    <div class="absolute top-20 left-10 -z-10 h-72 w-72 rounded-full bg-primary/20 mix-blend-screen blur-3xl filter animate-float"></div>
    <div class="absolute top-40 right-1/4 -z-10 h-72 w-72 rounded-full bg-secondary/20 mix-blend-screen blur-3xl filter animate-float" style="animation-delay: 2s;"></div>

    <div class="order-1 w-full lg:order-1 relative z-10">
      <h1 class="font-display text-5xl font-extrabold tracking-tight text-white md:text-6xl xl:text-[4rem] leading-[1.15] max-w-2xl">
        <span class="text-gradient block mb-3">AI Agent</span>
        <span class="block text-4xl md:text-5xl xl:text-5xl opacity-90 leading-tight">安全运行环境<br class="hidden sm:block"/>为每一个智能体保驾护航</span>
      </h1>
      <p class="mt-6 max-w-xl text-lg text-text-muted leading-relaxed">
        守护 Agent 可信运行，让人人安全使用 AI 能力
      </p>
      
      <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
        <Link href="#trial" style="primary" class="flex items-center justify-center w-full sm:w-auto group">
          立即使用
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </Link>
        <Link
          size="lg"
          style="outline"
          href="#demo"
          class="flex items-center justify-center w-full sm:w-auto gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
          </svg>
          观看 Demo 视频
        </Link>
      </div>

      <div class="mt-12 pt-8 border-t border-white/10">
        <p class="text-sm font-medium text-text-muted mb-4">已获得 100+ 企业信任</p>
        <div class="flex items-center gap-6 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
          <!-- Placeholder logos using text for now -->
          <span class="font-display font-bold text-xl text-white">Acme Corp</span>
          <span class="font-display font-bold text-xl text-white">TechFlow</span>
          <span class="font-display font-bold text-xl text-white">Nexus</span>
          <span class="font-display font-bold text-xl text-white">Stark Ind</span>
        </div>
      </div>
    </div>

    <div class="order-2 w-full lg:order-2 relative animate-fade-in-up" style="animation-delay: 0.1s;">
      <!-- Glowing background behind image -->
      <div class="absolute -inset-4 rounded-[2.5rem] bg-gradient-to-tr from-primary/30 to-secondary/30 opacity-50 blur-3xl animate-pulse-slow"></div>
      
      <!-- Network topology nodes (CSS drawn) -->
      <div class="absolute -top-10 -right-10 w-20 h-20 border border-primary/30 rounded-full flex items-center justify-center animate-float" style="animation-delay: 1s;">
        <div class="w-2 h-2 bg-primary rounded-full animate-glow-pulse"></div>
      </div>
      <div class="absolute -bottom-10 -left-10 w-32 h-32 border border-secondary/30 rounded-full flex items-center justify-center animate-float" style="animation-delay: 2s;">
        <div class="w-3 h-3 bg-secondary rounded-full animate-pulse"></div>
      </div>
      
      <!-- The mockup container -->
      <div class="relative rounded-2xl glass-card p-2 shadow-2xl shadow-primary/10 overflow-hidden">
        <!-- Browser / Mac Top Bar -->
        <div class="flex items-center gap-2 px-3 py-2.5">
          <div class="flex gap-1.5">
            <div class="h-3 w-3 rounded-full bg-red-500 border border-red-600"></div>
            <div class="h-3 w-3 rounded-full bg-amber-500 border border-amber-600"></div>
            <div class="h-3 w-3 rounded-full bg-green-500 border border-green-600"></div>
          </div>
        </div>
        
        <!-- Image wrapper -->
        <div class="rounded-xl overflow-hidden border border-white/5 bg-[#0a0e27] shadow-inner relative">
          <img
            src="/assets/dashboard.png"
            alt="Agents-of-Shield Dashboard"
            class="w-full object-cover rounded-xl"
          />
          <!-- Scanning overlay effect -->
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary/10 to-transparent h-1/2 animate-[float_3s_ease-in-out_infinite]"></div>
        </div>
      </div>
    </div>
  </main>
</Container>
