---
import Container from "./Container.astro";

const supportedSources = [
  "Codex",
  "Claude Code",
  "Antigravity",
  "Open Code",
  "Qwen Code",
  "Gemini CLI",
  "OpenClaw",
];
---

<section id="architecture" class="relative py-10 lg:py-12">
  <Container>
    <div class="compatibility-band overflow-hidden rounded-[32px] px-6 py-8 sm:px-8 lg:px-10 lg:py-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,290px)_1fr] lg:items-center">
        <div>
          <div class="eyebrow">Compatibility</div>
          <h2 class="mt-4 max-w-[10ch] font-display text-[clamp(2rem,3.2vw,2.9rem)] font-medium leading-[1.04] tracking-[-0.04em] text-[var(--color-ink)]">
            兼容主流 Agent 运行时
          </h2>
          <p class="copy-measure mt-4 text-[1rem] leading-7 tracking-[0.01em] text-[var(--color-gray-500)]">
            无侵入接入常见 Agent CLI 与桌面端，OTLP 日志与事件流直接落到 AOS 面板。
          </p>
        </div>

        <div class="compatibility-list">
          {
            supportedSources.map((source) => (
              <div class="compatibility-tile">
                <span>{source}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .compatibility-band {
    border: 1px solid rgba(24, 29, 38, 0.08);
    background:
      linear-gradient(180deg, rgba(249, 251, 255, 0.96) 0%, rgba(255, 255, 255, 1) 100%);
    box-shadow: 0 28px 60px rgba(15, 23, 42, 0.04);
  }

  .compatibility-tile {
    display: flex;
    min-height: 74px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(24, 29, 38, 0.08);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.96);
    padding: 14px 16px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    white-space: nowrap;
  }

  .compatibility-list {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: stretch;
    justify-content: flex-start;
  }

  .compatibility-list .compatibility-tile {
    flex: 0 0 auto;
    min-width: 136px;
  }

  @media (max-width: 767px) {
    .compatibility-list .compatibility-tile {
      min-width: calc(50% - 6px);
    }
  }
</style>
