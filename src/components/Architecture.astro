---
import Container from "./Container.astro";

const supportedSources = [
  "Codex",
  "Claude Code",
  "Antigravity",
  "Open Code",
  "Qwen Code",
  "Gemini CLI",
  "OpenClaw",
];
---

<section id="architecture" class="relative py-18 lg:py-20">
  <Container>
    <div class="grid gap-4 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)] lg:items-end">
      <div>
        <div class="eyebrow">Supported Sources</div>
        <h2 class="section-title mt-4">当前已支持的数据源</h2>
      </div>
      <p class="section-copy max-w-xl lg:justify-self-end">
        目前可直接接入这些 agent 来源。
      </p>
    </div>

    <div class="surface-card mt-10 p-6 sm:p-8 lg:p-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,0.88fr)_minmax(0,1.12fr)] lg:items-center">
        <div>
          <div class="text-[11px] font-semibold uppercase tracking-[1px] text-[var(--color-gray-300)]">
            Code Agents
          </div>
          <h3 class="mt-4 max-w-[12ch] font-display text-[1.8rem] font-medium leading-[1.12] tracking-[0.02px] text-[var(--color-ink)]">
            当前支持这些 agent
          </h3>
          <p class="mt-4 max-w-[32rem] text-sm leading-7 tracking-[0.08px] text-[var(--color-gray-500)]">
            接入后会统一进入桌面端面板，继续查看资产、扫描结果和活动事件。
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          {
            supportedSources.map((source) => (
              <span class="data-pill min-h-[40px] bg-white px-4 text-[var(--color-gray-700)]">{source}</span>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>
