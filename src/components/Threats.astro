---
import Container from "./Container.astro";

const threats = [
  {
    label: "Prompt Injection",
    title: "提示注入攻击",
    metric: "73%",
    description: "输入内容诱导 Agent 偏离原本边界。",
    response: "用运行时策略拦截高危指令。",
    tone: "background: rgba(238, 29, 54, 0.08); color: var(--color-red);",
  },
  {
    label: "Privilege Creep",
    title: "权限横向移动",
    metric: "12",
    description: "Agent 默认绑定的权限往往比实际需要更多。",
    response: "按任务上下文收紧 scope。",
    tone: "background: rgba(255, 107, 0, 0.1); color: var(--color-orange);",
  },
  {
    label: "MCP Supply Chain",
    title: "MCP 供应链风险",
    metric: "85%",
    description: "第三方服务可能携带隐藏能力和异常行为。",
    response: "对来源、依赖和能力做审计。",
    tone: "background: rgba(122, 61, 255, 0.1); color: var(--color-purple);",
  },
];
---

<section id="threats" class="relative py-20 lg:py-24">
  <Container>
    <div class="grid gap-4 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)] lg:items-end">
      <div>
        <div class="eyebrow">Threat Model</div>
        <h2 class="section-title mt-4">三类核心风险</h2>
      </div>
      <p class="section-copy max-w-xl lg:justify-self-end">
        Prompt、权限和第三方能力，是 Agent 最常见的风险来源。
      </p>
    </div>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        threats.map((threat) => (
          <article class="surface-card p-6 lg:p-7">
            <span class="accent-chip" style={threat.tone}>{threat.label}</span>
            <div class="mt-5 font-display text-[2.2rem] font-medium leading-none tracking-[0.08px]" style={`color: ${threat.tone.split("color: ")[1].replace(";", "")};`}>
              {threat.metric}
            </div>
            <h3 class="mt-4 font-display text-[1.45rem] font-medium leading-[1.2] tracking-[0.04px] text-[var(--color-ink)]">
              {threat.title}
            </h3>
            <p class="mt-3 text-sm leading-6 tracking-[0.08px] text-[var(--color-gray-500)]">
              {threat.description}
            </p>
            <div class="mt-6 border-t border-[var(--color-border)] pt-4 text-sm leading-6 tracking-[0.08px] text-[var(--color-gray-700)]">
              {threat.response}
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>
