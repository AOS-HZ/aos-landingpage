---
import Container from "./Container.astro";

const threats = [
  {
    label: "Prompt Injection",
    title: "提示注入攻击",
    metric: "73%",
    description: "输入内容诱导 Agent 偏离原本边界。",
    response: "用运行时策略拦截高危指令。",
    tone: "background: rgba(238, 29, 54, 0.08); color: var(--color-red);",
  },
  {
    label: "Privilege Creep",
    title: "权限横向移动",
    metric: "12",
    description: "Agent 默认绑定的权限往往比实际需要更多。",
    response: "按任务上下文收紧 scope。",
    tone: "background: rgba(255, 107, 0, 0.1); color: var(--color-orange);",
  },
  {
    label: "MCP Supply Chain",
    title: "MCP 供应链风险",
    metric: "85%",
    description: "第三方服务可能携带隐藏能力和异常行为。",
    response: "对来源、依赖和能力做审计。",
    tone: "background: rgba(122, 61, 255, 0.1); color: var(--color-purple);",
  },
];
---

<section id="threats" class="relative pt-12 pb-8 lg:pt-14 lg:pb-10">
  <Container>
    <div class="mx-auto max-w-[760px] text-center">
      <div class="eyebrow justify-center">Risk Model</div>
      <h2 class="section-title mt-4">三类最常见的 Agent 风险来源</h2>
      <p class="section-copy copy-measure copy-measure--center mt-5">
        Prompt、权限和第三方来源，是 Agent 最常见的三类风险入口，也是运行时治理最先要收住的地方。
      </p>
    </div>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {
        threats.map((threat, index) => (
          <article class="surface-card p-6 lg:p-7">
            <div class="flex items-center justify-between gap-4">
              <span class="accent-chip" style={threat.tone}>{threat.label}</span>
              <span class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-gray-300)]">
                0{index + 1}
              </span>
            </div>
            <h3 class="mt-6 font-display text-[1.55rem] font-medium leading-[1.16] tracking-[-0.03em] text-[var(--color-ink)]">
              {threat.title}
            </h3>
            <p class="mt-3 text-[15px] leading-7 tracking-[0.01em] text-[var(--color-gray-500)]">
              {threat.description}
            </p>

            <div class="mt-7 rounded-[22px] border border-[rgba(24,29,38,0.06)] bg-[var(--color-surface-alt)] p-5">
              <div class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--color-gray-300)]">
                Key signal
              </div>
              <div class="mt-3 font-display text-[2rem] font-medium leading-none tracking-[-0.04em]" style={`color: ${threat.tone.split("color: ")[1].replace(";", "")};`}>
                {threat.metric}
              </div>
              <div class="mt-4 text-sm leading-6 tracking-[0.01em] text-[var(--color-gray-700)]">
                {threat.response}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>
