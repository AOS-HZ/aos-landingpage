---
import Container from "./Container.astro";
import SectionHead from "./SectionHead.astro";

const screens = [
  {
    title: "组件管理",
    body: "把已安装组件与来源拆开管理，环境边界更清楚。",
    image: "/assets/skills-management.png",
  },
  {
    title: "风险分析",
    body: "每条发现都能追到具体规则、路径和原因，不只是一条告警。",
    image: "/assets/risk-analysis.png",
  },
  {
    title: "隔离区",
    body: "先移出活跃环境，再决定恢复、观察还是清理。",
    image: "/assets/quarantine-zone.png",
  },
  {
    title: "活动监控",
    body: "把后续变动持续保留下来，避免扫描结果很快失效。",
    image: "/assets/activity-monitor.png",
  },
];
---

<Container>
  <section id="screens" class="mt-32 md:mt-40 scroll-mt-24">
    <SectionHead
      label="Product Screens"
      title="可见的安全处理路径。"
      body="从总览、分析、隔离到持续监控，这些界面不是零散展示，而是同一条安全工作流的不同视角。"
    />

    <div class="mt-16 grid gap-8 md:grid-cols-2">
      {
        screens.map((screen) => (
          <article class="group relative overflow-hidden rounded-[2rem] border border-slate-200/60 bg-white/60 p-2 shadow-sm backdrop-blur-md transition-all duration-300 hover:shadow-xl hover:shadow-slate-200/50 hover:border-slate-300">
            <div class="px-6 py-6 sm:px-8">
              <h3 class="font-display text-2xl font-bold tracking-tight text-slate-900">
                {screen.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600 line-clamp-2">{screen.body}</p>
            </div>
            
            <div class="mt-2 rounded-2xl bg-slate-100/50 p-2">
              <div class="rounded-xl overflow-hidden border border-slate-200/50 bg-white shadow-sm ring-1 ring-slate-900/5 transition-transform duration-500 group-hover:scale-[1.02]">
                <!-- Mac Top Bar -->
                <div class="flex items-center gap-1.5 border-b border-slate-100 bg-slate-50/50 px-3 py-2">
                  <div class="h-2 w-2 rounded-full bg-slate-300"></div>
                  <div class="h-2 w-2 rounded-full bg-slate-300"></div>
                  <div class="h-2 w-2 rounded-full bg-slate-300"></div>
                </div>
                <!-- Image -->
                <img src={screen.image} alt={screen.title} class="w-full object-cover object-top" loading="lazy" />
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</Container>
