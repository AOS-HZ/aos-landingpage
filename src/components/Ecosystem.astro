---
import Container from "./Container.astro";

const deploymentModes = [
  {
    title: "Desktop",
    body: "先在桌面端盘点与扫描本地 Agent。",
  },
  {
    title: "CLI",
    body: "直接在命令行里接入扫描与治理流程。",
  },
  {
    title: "Cloud",
    body: "把共享策略和结果同步给团队环境。",
  },
];

const categories = [
  {
    title: "LLM 平台",
    items: ["OpenAI", "Anthropic", "Azure OpenAI"],
    tone: "background: rgba(27, 97, 201, 0.1); color: var(--color-primary);",
  },
  {
    title: "Agent 框架",
    items: ["LangChain", "LlamaIndex", "AutoGen"],
    tone: "background: rgba(122, 61, 255, 0.12); color: var(--color-purple);",
  },
  {
    title: "开发工具",
    items: ["GitHub", "Docker", "Kubernetes"],
    tone: "background: rgba(255, 107, 0, 0.12); color: var(--color-orange);",
  },
  {
    title: "安全生态",
    items: ["Splunk", "Datadog", "ServiceNow"],
    tone: "background: rgba(0, 100, 0, 0.1); color: var(--color-green);",
  },
];
---

<section id="ecosystem" class="relative py-20 lg:py-24">
  <Container>
    <div class="surface-card overflow-hidden p-6 sm:p-8 lg:p-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,0.78fr)_minmax(0,1.22fr)]">
        <div>
          <div class="eyebrow">Ecosystem</div>
          <h2 class="section-title mt-4">接进现有技术栈</h2>
          <p class="section-copy copy-measure mt-5">
            不重做工作流，继续沿用团队已经在用的模型、框架、开发工具和安全系统。
          </p>

          <div class="mt-7 grid gap-3">
            {
              deploymentModes.map((mode) => (
                <article class="surface-panel rounded-[18px] p-4">
                  <div class="flex items-center justify-between gap-3">
                    <div class="font-display text-[1rem] font-medium text-[var(--color-ink)]">{mode.title}</div>
                    <span class="data-pill bg-white text-[var(--color-gray-700)]">Ready</span>
                  </div>
                  <p class="mt-3 max-w-[20rem] text-sm leading-6 tracking-[0.08px] text-[var(--color-gray-500)]">
                    {mode.body}
                  </p>
                </article>
              ))
            }
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {
            categories.map((category) => (
              <article class="surface-panel flex h-full flex-col p-5">
                <span class="accent-chip self-start" style={category.tone}>{category.title}</span>

                <div class="mt-5 space-y-2">
                  {category.items.map((item) => (
                    <div class="flex items-center justify-between rounded-[12px] border border-[var(--color-border)] bg-white px-4 py-3 text-sm text-[var(--color-gray-700)]">
                      <span>{item}</span>
                      <span class="text-[11px] font-semibold uppercase tracking-[0.9px] text-[var(--color-gray-300)]">
                        Ready
                      </span>
                    </div>
                  ))}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>
