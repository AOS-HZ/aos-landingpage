---
import Container from "./Container.astro";
import SectionHead from "./SectionHead.astro";

const steps = [
  {
    title: "Discover",
    body: "扫描本地安装面，先建立组件清单。",
  },
  {
    title: "Classify",
    body: "按来源、能力和类型拆分生态视图。",
  },
  {
    title: "Inspect",
    body: "围绕真实行为应用规则并生成信号。",
  },
  {
    title: "Quarantine",
    body: "对高风险组件执行隔离和处置。",
  },
  {
    title: "Monitor",
    body: "持续观察后续变化和恢复动作。",
  },
];
---

<Container>
  <section id="workflow" class="mt-32 md:mt-40 scroll-mt-24">
    <SectionHead
      label="Workflow"
      title="不仅是检查，更是工作流。"
      body="AOS 先盘点环境，再把风险信号变成可读事实，最后给出隔离与后续监控的位置。"
    />

    <div class="mt-16 grid gap-4 md:grid-cols-2 xl:grid-cols-5 relative">
      <!-- Connection line for desktop -->
      <div class="hidden xl:block absolute top-[2.5rem] left-8 right-8 h-px bg-gradient-to-r from-transparent via-blue-200 to-transparent -z-10"></div>
      
      {
        steps.map((item, index) => (
          <article class="group relative rounded-[1.5rem] border border-slate-200/50 bg-white/50 p-6 shadow-sm backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-blue-900/5 hover:border-blue-200 hover:bg-white/80">
            <div class="mb-4 flex h-8 w-8 items-center justify-center rounded-full bg-blue-50 text-xs font-bold text-blue-600 ring-4 ring-white transition-all group-hover:bg-blue-600 group-hover:text-white">
              {index + 1}
            </div>
            <p class="font-mono text-[0.7rem] font-bold uppercase tracking-[0.2em] text-slate-800 transition-colors group-hover:text-blue-600">
              {item.title}
            </p>
            <p class="mt-3 text-sm leading-relaxed text-slate-600 group-hover:text-slate-700">{item.body}</p>
          </article>
        ))
      }
    </div>
  </section>
</Container>
