---
import Container from "./Container.astro";
import Link from "./ui/Link.astro";
import ShieldMark from "./ShieldMark.astro";
import { DOCS_URL } from "../constants/site";

const menuitems = [
  { title: "兼容生态", path: "#architecture" },
  { title: "核心能力", path: "#features" },
  { title: "风险治理", path: "#threats" },
  { title: "客户案例", path: "#customers" },
];
---

<header class="border-b border-[rgba(24,29,38,0.08)] bg-white/96 animate-[var(--animate-rise-in)]">
  <Container class="flex min-h-[80px] items-center justify-between gap-4 lg:min-h-[92px]">
    <a href="/" class="group flex items-center gap-3">
      <ShieldMark class="h-10 w-10 text-[var(--color-primary)] transition-transform duration-200 group-hover:-translate-y-0.5" />
      <div>
        <div class="font-display text-[1.05rem] font-semibold leading-none tracking-[-0.02em] text-[var(--color-ink)] sm:text-[1.18rem]">
          AOS
        </div>
        <div class="mt-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-[var(--color-gray-300)]">
          Agent Security Ops
        </div>
      </div>
    </a>

    <nav class="hidden items-center gap-1 lg:flex">
      {
        menuitems.map((item) => (
          <a
            href={item.path}
            class="rounded-[999px] px-4 py-3 text-[15px] font-medium tracking-[-0.01em] text-[var(--color-gray-500)] transition-colors hover:text-[var(--color-ink)]"
          >
            {item.title}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={DOCS_URL}
        class="hidden min-h-[44px] items-center rounded-[14px] border border-[var(--color-border-strong)] bg-white px-5 text-[15px] font-medium tracking-[-0.01em] text-[var(--color-ink)] transition-colors hover:border-[var(--color-ink)] sm:inline-flex"
      >
        阅读文档
      </a>
      <Link href="#cta" size="md" style="secondary" class="rounded-[14px] px-5 shadow-none">
        开始体验
      </Link>
    </div>
  </Container>
</header>
