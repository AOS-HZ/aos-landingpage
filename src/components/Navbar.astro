---
import Container from "./Container.astro";
import Link from "./ui/Link.astro";
import ShieldMark from "./ShieldMark.astro";

const menuitems = [
  { title: "Features", path: "#features" },
  { title: "Surfaces", path: "#surfaces" },
  { title: "Screens", path: "#screens" },
  { title: "Workflow", path: "#workflow" },
];
---

<div class="fixed top-4 left-0 right-0 z-50 flex justify-center px-4 animate-fade-in-up">
  <header class="flex w-full max-w-5xl items-center justify-between gap-4 rounded-full border border-white/40 bg-white/70 px-4 py-3 shadow-[0_8px_30px_rgb(0,0,0,0.04)] backdrop-blur-md transition-all sm:px-6">
    <a href="/" class="flex items-center gap-2.5 text-lg transition-transform hover:scale-105">
      <ShieldMark class="h-8 w-8 text-blue-600 drop-shadow-sm" />
      <span class="hidden sm:inline-block">
        <span class="font-display font-bold tracking-tight text-slate-900">Agents</span>
        <span class="font-display text-slate-500">ofShield</span>
      </span>
    </a>

    <nav class="hidden md:flex flex-wrap items-center justify-center gap-1">
      {
        menuitems.map((item) => (
          <a
            href={item.path}
            class="rounded-full px-4 py-2 font-mono text-[0.7rem] uppercase tracking-[0.16em] text-slate-500 transition-all hover:bg-slate-900/5 hover:text-slate-900"
          >
            {item.title}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="#screens"
        class="hidden sm:inline-block font-mono text-[0.7rem] uppercase tracking-[0.16em] text-slate-500 transition-colors hover:text-slate-900"
      >
        Preview
      </a>
      <Link href="#launch" size="md" class="!rounded-full shadow-sm hover:shadow-md transition-all hover:-translate-y-0.5">Book Demo</Link>
    </div>
  </header>
</div>

