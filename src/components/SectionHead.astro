---
interface Props {
  label: string;
  title: string;
  body: string;
  align?: "left" | "center";
}

const { label, title, body, align = "left" } = Astro.props;
const centered = align === "center";
---

<div class:list={["max-w-3xl", centered && "mx-auto text-center"]}>
  <p class="font-mono text-xs uppercase tracking-[0.22em] text-slate-500">
    {label}
  </p>
  <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-slate-950 md:text-5xl">
    {title}
  </h2>
  <p class="mt-4 text-lg leading-8 text-slate-600">
    {body}
  </p>
</div>
