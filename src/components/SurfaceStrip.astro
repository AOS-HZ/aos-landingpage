---
import Container from "./Container.astro";

const surfaces = [
  "Skills",
  "Plugins",
  "MCP Servers",
  "Tools",
  "Prompts",
];
---

<Container>
  <section id="surfaces" class="mt-20">
    <h2 class="text-center text-sm uppercase tracking-[0.18em] text-slate-500">
      Inspection Surfaces
    </h2>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3 md:gap-5">
      {
        surfaces.map((item) => (
          <div class="rounded-full border border-slate-200 bg-white px-5 py-3 font-display text-lg tracking-tight text-slate-900 shadow-sm md:text-2xl">
            {item}
          </div>
        ))
      }
    </div>
  </section>
</Container>
