---
import Container from "./Container.astro";

const surfaces = [
  "Skills",
  "Plugins",
  "MCP Servers",
  "Tools",
  "Prompts",
];
---

<Container>
  <section id="surfaces" class="mt-20">
    <h2 class="text-center font-mono text-xs uppercase tracking-[0.2em] font-medium text-slate-500">
      Inspection Surfaces
    </h2>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3 md:gap-5">
      {
        surfaces.map((item) => (
          <div class="group relative rounded-full border border-slate-200/60 bg-white/70 backdrop-blur-md px-6 py-3.5 font-display text-lg font-medium tracking-tight text-slate-700 shadow-sm transition-all hover:-translate-y-1 hover:border-blue-200 hover:bg-white hover:text-slate-900 hover:shadow-md md:text-2xl cursor-default">
            <div class="absolute inset-0 rounded-full bg-gradient-to-r from-blue-50 to-indigo-50 opacity-0 transition-opacity group-hover:opacity-100 -z-10"></div>
            {item}
          </div>
        ))
      }
    </div>
  </section>
</Container>
