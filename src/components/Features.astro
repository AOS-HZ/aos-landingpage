---
import Container from "./Container.astro";

const tabs = [
  {
    id: "overview",
    number: "01",
    nav: "多 Agent 总览",
    eyebrow: "Overview",
    title: "把多家 Agent 收进同一块面板",
    description: "Token、调用、成本与防护状态一目了然。",
    cta: "查看总览",
    image: "/assets/overview-dashboard.png",
    theme:
      "linear-gradient(180deg, #2457d3 0%, #163f9e 100%)",
    glow: "rgba(36, 87, 211, 0.26)",
    labels: ["AGENTS", "METRICS", "COST"],
    positions: ["14% 10%", "56% 6%", "90% 14%"],
  },
  {
    id: "sessions",
    number: "02",
    nav: "会话追溯",
    eyebrow: "Sessions",
    title: "按会话还原每一次工具调用",
    description: "风险打分、Token 走势与耗时同屏展示。",
    cta: "查看会话",
    image: "/assets/sessions-inspector.png",
    theme:
      "linear-gradient(180deg, #0f7a71 0%, #075e58 100%)",
    glow: "rgba(15, 122, 113, 0.24)",
    labels: ["SESSION", "TOOLS", "RISK"],
    positions: ["18% 10%", "54% 14%", "88% 8%"],
  },
  {
    id: "alerts",
    number: "03",
    nav: "告警拦截",
    eyebrow: "Alerts",
    title: "高危工具调用第一时间拦截",
    description: "每条告警都有定位会话与原始载荷。",
    cta: "查看告警",
    image: "/assets/alerts-center.png",
    theme:
      "linear-gradient(180deg, #a33c28 0%, #862d1b 100%)",
    glow: "rgba(163, 60, 40, 0.24)",
    labels: ["BLOCKED", "RULE", "SESSION"],
    positions: ["12% 18%", "54% 16%", "88% 12%"],
  },
  {
    id: "canvas",
    number: "04",
    nav: "调用链还原",
    eyebrow: "Live Canvas",
    title: "把工具、模型与告警摆上同一画布",
    description: "沿时间轴一眼看清 Agent 的决策路径。",
    cta: "查看 Live Canvas",
    image: "/assets/live-canvas.png",
    theme:
      "linear-gradient(180deg, #7a3dff 0%, #5f27d8 100%)",
    glow: "rgba(122, 61, 255, 0.24)",
    labels: ["INPUT", "TOOLS", "OUTPUT"],
    positions: ["12% 8%", "54% 8%", "88% 8%"],
  },
];
---

<section id="features" class="relative py-10 lg:py-12">
  <Container>
    <div id="feature-showcase" class="feature-showcase overflow-hidden rounded-[40px] border border-[rgba(24,29,38,0.08)] bg-white shadow-[0_26px_60px_rgba(15,23,42,0.05)]">
      <div class="feature-showcase__nav">
        <div class="feature-showcase__intro">
          <div class="eyebrow">Core Workflow</div>
          <h2 class="feature-showcase__title">四个核心能力</h2>
        </div>

        {
          tabs.map((tab, index) => (
            <button
              type="button"
              class:list={["feature-nav-item", index === 0 && "is-active"]}
              data-feature-trigger
              data-feature-id={tab.id}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              <span class="feature-nav-item__marker"></span>
              <span class="feature-nav-item__number">{tab.number}</span>
              <span class="feature-nav-item__label">{tab.nav}</span>
            </button>
          ))
        }
      </div>

      <div class="feature-showcase__stage">
        {
          tabs.map((tab, index) => (
            <article
              class:list={["feature-panel", index === 0 && "is-active"]}
              data-feature-panel
              data-feature-id={tab.id}
              style={`--feature-panel-bg:${tab.theme}; --feature-panel-glow:${tab.glow};`}
            >
              <div class="feature-panel__head">
                <div>
                  <div class="feature-panel__eyebrow">{tab.eyebrow}</div>
                  <h3 class="feature-panel__title">{tab.title}</h3>
                  <p class="feature-panel__description">{tab.description}</p>
                </div>
                <a href="#cta" class="feature-panel__cta">{tab.cta}</a>
              </div>

              <div class="feature-panel__visual">
                <div class="feature-visual-card feature-visual-card--back">
                  <span class="feature-visual-card__label">{tab.labels[0]}</span>
                  <img src={tab.image} alt="" style={`object-position:${tab.positions[0]};`} />
                </div>

                <div class="feature-visual-card feature-visual-card--mid">
                  <span class="feature-visual-card__label">{tab.labels[1]}</span>
                  <img src={tab.image} alt="" style={`object-position:${tab.positions[1]};`} />
                </div>

                <div class="feature-visual-card feature-visual-card--front">
                  <span class="feature-visual-card__label">{tab.labels[2]}</span>
                  <img src={tab.image} alt="" style={`object-position:${tab.positions[2]};`} />
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </Container>
</section>

<style>
  .feature-showcase {
    display: grid;
    grid-template-columns: minmax(0, 318px) minmax(0, 1fr);
    height: min(74vh, 760px);
    min-height: 680px;
  }

  .feature-showcase__nav {
    display: flex;
    flex-direction: column;
    padding: 34px 36px 28px 34px;
    background: #fff;
  }

  .feature-showcase__intro {
    margin-bottom: 12px;
    padding-bottom: 22px;
    border-bottom: 1px solid rgba(24, 29, 38, 0.08);
  }

  .feature-showcase__title {
    margin: 14px 0 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 2.8vw, 2.85rem);
    font-weight: 500;
    line-height: 1.06;
    letter-spacing: -0.05em;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .feature-nav-item {
    display: grid;
    grid-template-columns: 12px 36px minmax(0, 1fr);
    align-items: center;
    gap: 12px;
    width: 100%;
    border: 0;
    border-top: 1px solid rgba(24, 29, 38, 0.08);
    background: transparent;
    padding: 22px 0;
    text-align: left;
    color: rgba(24, 29, 38, 0.42);
    transition: color 0.24s ease, transform 0.24s ease;
  }

  .feature-nav-item:first-child {
    border-top: 0;
  }

  .feature-nav-item:hover {
    transform: translateX(2px);
    color: rgba(24, 29, 38, 0.72);
  }

  .feature-nav-item.is-active {
    color: var(--color-ink);
  }

  .feature-nav-item__marker {
    height: 10px;
    width: 10px;
    border-radius: 2px;
    background: transparent;
    transition: background-color 0.24s ease;
  }

  .feature-nav-item.is-active .feature-nav-item__marker {
    background: #a33c28;
  }

  .feature-nav-item__number {
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .feature-nav-item__label {
    font-size: 15px;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.02em;
  }

  .feature-showcase__stage {
    position: relative;
    min-height: 0;
  }

  .feature-panel {
    position: absolute;
    inset: 14px 14px 14px 0;
    overflow: hidden;
    border-radius: 28px;
    background: var(--feature-panel-bg);
    opacity: 0;
    pointer-events: none;
    transform: translateY(22px);
    transition:
      opacity 0.38s ease,
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .feature-panel.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .feature-panel::before {
    content: "";
    position: absolute;
    inset: auto 12% 6% 16%;
    height: 40%;
    border-radius: 999px;
    background: radial-gradient(circle, var(--feature-panel-glow) 0%, rgba(255, 255, 255, 0) 72%);
    filter: blur(30px);
    pointer-events: none;
  }

  .feature-panel__head {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 20px;
    padding: 42px 44px 0;
    color: white;
  }

  .feature-panel__eyebrow {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.78;
  }

  .feature-panel__title {
    margin: 14px 0 0;
    max-width: 12ch;
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.4vw, 3rem);
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .feature-panel__description {
    margin: 12px 0 0;
    max-width: 24ch;
    font-size: 1rem;
    line-height: 1.5;
    letter-spacing: -0.01em;
    opacity: 0.86;
  }

  .feature-panel__cta {
    align-self: start;
    display: inline-flex;
    min-height: 64px;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.96);
    padding: 0 24px;
    font-size: 0.96rem;
    font-weight: 600;
    color: var(--color-ink);
    box-shadow: 0 18px 40px rgba(13, 20, 33, 0.12);
  }

  .feature-panel__visual {
    position: absolute;
    inset: 0;
  }

  .feature-visual-card {
    position: absolute;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.16);
    box-shadow:
      0 22px 40px rgba(11, 19, 31, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(10px);
    opacity: 0;
    transition:
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.45s ease;
  }

  .feature-panel.is-active .feature-visual-card {
    opacity: 1;
  }

  .feature-visual-card img {
    height: 100%;
    width: 100%;
    object-fit: cover;
    opacity: 0.38;
    mix-blend-mode: screen;
  }

  .feature-visual-card__label {
    position: absolute;
    left: 20px;
    top: 18px;
    z-index: 2;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
  }

  .feature-visual-card--back {
    left: 10%;
    bottom: -4%;
    width: 220px;
    height: 356px;
    transform: translate3d(-18px, 42px, 0) rotate(-28deg);
  }

  .feature-panel.is-active .feature-visual-card--back {
    transform: translate3d(0, 0, 0) rotate(-28deg);
    transition-delay: 0.06s;
  }

  .feature-visual-card--mid {
    left: 38%;
    bottom: -3%;
    width: 226px;
    height: 368px;
    transform: translate3d(-8px, 48px, 0) rotate(-16deg);
  }

  .feature-panel.is-active .feature-visual-card--mid {
    transform: translate3d(0, 0, 0) rotate(-16deg);
    transition-delay: 0.14s;
  }

  .feature-visual-card--front {
    right: 8%;
    bottom: -3%;
    width: 248px;
    height: 378px;
    transform: translate3d(14px, 52px, 0) rotate(-7deg);
  }

  .feature-panel.is-active .feature-visual-card--front {
    transform: translate3d(0, 0, 0) rotate(-7deg);
    transition-delay: 0.22s;
  }

  .feature-panel[data-feature-id="alerts"] {
    transform: translate3d(34px, 10px, 0) scale(0.985);
  }

  .feature-panel[data-feature-id="alerts"].is-active {
    transform: translate3d(0, 0, 0) scale(1);
  }

  .feature-panel[data-feature-id="alerts"] .feature-panel__head > div,
  .feature-panel[data-feature-id="alerts"] .feature-panel__cta {
    opacity: 0;
    transition:
      transform 0.62s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.32s ease;
  }

  .feature-panel[data-feature-id="alerts"] .feature-panel__head > div {
    transform: translate3d(-28px, 0, 0);
  }

  .feature-panel[data-feature-id="alerts"] .feature-panel__cta {
    transform: translate3d(24px, 0, 0);
  }

  .feature-panel[data-feature-id="alerts"].is-active .feature-panel__head > div,
  .feature-panel[data-feature-id="alerts"].is-active .feature-panel__cta {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .feature-panel[data-feature-id="alerts"].is-active .feature-panel__head > div {
    transition-delay: 0.06s;
  }

  .feature-panel[data-feature-id="alerts"].is-active .feature-panel__cta {
    transition-delay: 0.12s;
  }

  .feature-panel[data-feature-id="alerts"] .feature-visual-card--back {
    transform: translate3d(-54px, 56px, 0) rotate(-42deg) scale(0.92);
  }

  .feature-panel[data-feature-id="alerts"].is-active .feature-visual-card--back {
    transform: translate3d(-10px, -6px, 0) rotate(-34deg) scale(1);
    transition-delay: 0.03s;
  }

  .feature-panel[data-feature-id="alerts"] .feature-visual-card--mid {
    transform: translate3d(6px, 78px, 0) rotate(-4deg) scale(0.9);
  }

  .feature-panel[data-feature-id="alerts"].is-active .feature-visual-card--mid {
    transform: translate3d(6px, -4px, 0) rotate(-8deg) scale(1);
    transition-delay: 0.14s;
  }

  .feature-panel[data-feature-id="alerts"] .feature-visual-card--front {
    transform: translate3d(62px, 52px, 0) rotate(14deg) scale(0.92);
  }

  .feature-panel[data-feature-id="alerts"].is-active .feature-visual-card--front {
    transform: translate3d(14px, -6px, 0) rotate(5deg) scale(1);
    transition-delay: 0.24s;
  }

  .feature-panel[data-feature-id="sessions"] {
    transform: translate3d(0, 38px, 0) scale(0.972);
  }

  .feature-panel[data-feature-id="sessions"].is-active {
    transform: translate3d(0, 0, 0) scale(1);
  }

  .feature-panel[data-feature-id="sessions"] .feature-panel__head > div,
  .feature-panel[data-feature-id="sessions"] .feature-panel__cta {
    opacity: 0;
    transition:
      transform 0.58s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.32s ease;
  }

  .feature-panel[data-feature-id="sessions"] .feature-panel__head > div {
    transform: translate3d(0, -20px, 0);
  }

  .feature-panel[data-feature-id="sessions"] .feature-panel__cta {
    transform: translate3d(0, 20px, 0);
  }

  .feature-panel[data-feature-id="sessions"].is-active .feature-panel__head > div,
  .feature-panel[data-feature-id="sessions"].is-active .feature-panel__cta {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  .feature-panel[data-feature-id="sessions"].is-active .feature-panel__head > div {
    transition-delay: 0.06s;
  }

  .feature-panel[data-feature-id="sessions"].is-active .feature-panel__cta {
    transition-delay: 0.14s;
  }

  .feature-panel[data-feature-id="sessions"] .feature-visual-card--back {
    transform: translate3d(-8px, 90px, 0) rotate(-10deg) scale(0.9);
  }

  .feature-panel[data-feature-id="sessions"].is-active .feature-visual-card--back {
    transform: translate3d(-12px, 6px, 0) rotate(-18deg) scale(1);
    transition-delay: 0.04s;
  }

  .feature-panel[data-feature-id="sessions"] .feature-visual-card--mid {
    transform: translate3d(0, 118px, 0) rotate(2deg) scale(0.88);
  }

  .feature-panel[data-feature-id="sessions"].is-active .feature-visual-card--mid {
    transform: translate3d(0, -10px, 0) rotate(-2deg) scale(1);
    transition-delay: 0.2s;
  }

  .feature-panel[data-feature-id="sessions"] .feature-visual-card--front {
    transform: translate3d(18px, 108px, 0) rotate(10deg) scale(0.9);
  }

  .feature-panel[data-feature-id="sessions"].is-active .feature-visual-card--front {
    transform: translate3d(8px, 2px, 0) rotate(6deg) scale(1);
    transition-delay: 0.12s;
  }

  @media (max-width: 1279px) {
    .feature-showcase {
      grid-template-columns: minmax(0, 1fr);
      height: auto;
      min-height: 0;
    }

    .feature-showcase__nav {
      padding: 24px 24px 18px;
    }

    .feature-showcase__intro {
      margin-bottom: 10px;
      padding-bottom: 18px;
    }

    .feature-showcase__stage {
      min-height: 640px;
    }

    .feature-panel {
      inset: 0 18px 18px;
    }
  }

  @media (max-width: 767px) {
    .feature-showcase {
      border-radius: 30px;
    }

    .feature-showcase__nav {
      padding: 18px 20px 12px;
    }

    .feature-showcase__intro {
      padding-bottom: 16px;
    }

    .feature-showcase__title {
      font-size: clamp(1.8rem, 7vw, 2.4rem);
    }

    .feature-nav-item {
      grid-template-columns: 12px 30px minmax(0, 1fr);
      padding: 14px 0;
    }

    .feature-showcase__stage {
      min-height: 560px;
    }

    .feature-panel {
      inset: 0 12px 12px;
      border-radius: 24px;
    }

    .feature-panel__head {
      grid-template-columns: minmax(0, 1fr);
      padding: 24px 24px 0;
    }

    .feature-panel__title {
      max-width: 11ch;
      font-size: clamp(1.9rem, 8vw, 2.6rem);
    }

    .feature-panel__description {
      max-width: 22ch;
      font-size: 0.98rem;
    }

    .feature-panel__cta {
      min-height: 52px;
      padding: 0 18px;
      border-radius: 16px;
      font-size: 0.94rem;
    }

    .feature-visual-card--back {
      left: 8%;
      width: 170px;
      height: 288px;
    }

    .feature-visual-card--mid {
      left: 34%;
      width: 176px;
      height: 300px;
    }

    .feature-visual-card--front {
      right: 6%;
      width: 194px;
      height: 310px;
    }

  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const root = document.getElementById("feature-showcase");
    if (!root) return;

    const triggers = Array.from(root.querySelectorAll("[data-feature-trigger]"));
    const panels = Array.from(root.querySelectorAll("[data-feature-panel]"));
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    let activeIndex = 0;
    let timerId = 0;

    const render = (index) => {
      activeIndex = index;
      const targetId = triggers[index]?.getAttribute("data-feature-id");
      if (!targetId) return;

      triggers.forEach((trigger, triggerIndex) => {
        const isActive = triggerIndex === index;
        trigger.classList.toggle("is-active", isActive);
        trigger.setAttribute("aria-pressed", isActive ? "true" : "false");
      });

      panels.forEach((panel) => {
        panel.classList.toggle("is-active", panel.getAttribute("data-feature-id") === targetId);
      });
    };

    const next = () => {
      render((activeIndex + 1) % triggers.length);
    };

    const stop = () => {
      if (timerId) window.clearInterval(timerId);
    };

    const start = () => {
      stop();
      if (prefersReducedMotion || triggers.length <= 1) return;
      timerId = window.setInterval(next, 4200);
    };

    triggers.forEach((trigger, index) => {
      trigger.addEventListener("click", () => {
        render(index);
        start();
      });

      trigger.addEventListener("mouseenter", () => {
        render(index);
        stop();
      });
    });

    root.addEventListener("mouseleave", start);
    root.addEventListener("focusin", stop);
    root.addEventListener("focusout", start);

    render(0);
    start();
  });
</script>
