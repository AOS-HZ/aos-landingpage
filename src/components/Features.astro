---
import Container from "./Container.astro";

const tabs = [
  {
    id: "tab-1",
    title: "Agent 资产发现",
    description: "自动盘点所有 AI Agent",
    image: "/assets/dashboard.png",
    active: true
  },
  {
    id: "tab-2",
    title: "Skills 安全扫描",
    description: "第三方工具链风险检测",
    image: "/assets/skills-management.png",
    active: false
  },
  {
    id: "tab-3",
    title: "运行时防护",
    description: "实时拦截恶意行为",
    image: "/assets/quarantine-zone.png",
    active: false
  },
  {
    id: "tab-4",
    title: "权限治理",
    description: "最小权限原则执行",
    image: "/assets/risk-analysis.png",
    active: false
  },
  {
    id: "tab-5",
    title: "审计与合规",
    description: "全链路日志追踪",
    image: "/assets/activity-monitor.png",
    active: false
  }
];
---

<section id="features" class="py-24 relative bg-white/5 border-y border-white/10 overflow-hidden">
  <!-- Background Glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/5 rounded-full blur-[100px] pointer-events-none"></div>

  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-6">全栈 Agent <span class="text-gradient">安全防护体系</span></h2>
      <p class="text-lg text-text-muted">构建从开发、测试到生产环境的端到端安全屏障</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-12 items-center">
      <!-- Tabs Menu -->
      <div class="w-full lg:w-1/3 flex flex-col gap-4 relative z-10" id="features-tabs">
        {
          tabs.map((tab, index) => (
            <button 
              class={`tab-btn text-left p-6 rounded-2xl border transition-all duration-300 relative overflow-hidden group ${tab.active ? 'bg-primary/10 border-primary shadow-[0_0_20px_rgba(0,212,170,0.15)]' : 'bg-transparent border-white/10 hover:border-white/30 hover:bg-white/5'}`}
              data-target={tab.id}
              data-image={tab.image}
            >
              {tab.active && (
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary active-indicator"></div>
              )}
              {!tab.active && (
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary/50 opacity-0 group-hover:opacity-100 transition-opacity active-indicator hidden"></div>
              )}
              <h3 class={`text-xl font-bold mb-2 transition-colors ${tab.active ? 'text-primary' : 'text-white group-hover:text-gray-200'}`}>
                {tab.title}
              </h3>
              <p class="text-text-muted text-sm">{tab.description}</p>
            </button>
          ))
        }
      </div>

      <!-- Interactive Demo Area -->
      <div class="w-full lg:w-2/3 relative z-10">
        <div class="glass-card p-2 rounded-2xl border border-white/10 shadow-2xl relative overflow-hidden">
          <!-- Terminal Header -->
          <div class="flex items-center gap-2 px-4 py-3 bg-[#0a0e27]/80 border-b border-white/5">
            <div class="flex gap-1.5">
              <div class="h-3 w-3 rounded-full bg-red-500 border border-red-600"></div>
              <div class="h-3 w-3 rounded-full bg-amber-500 border border-amber-600"></div>
              <div class="h-3 w-3 rounded-full bg-green-500 border border-green-600"></div>
            </div>
            <div class="ml-4 flex-1 flex justify-center">
              <div class="bg-black/50 text-xs text-text-muted px-4 py-1 rounded-full font-mono border border-white/5 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-primary animate-pulse inline-block"></span>
                ShieldAgent Console - <span id="console-title">Agent 资产发现</span>
              </div>
            </div>
          </div>

          <!-- Content Area -->
          <div class="bg-[#0a0e27] rounded-b-xl overflow-hidden relative min-h-[400px] flex items-center justify-center p-4">
            <img 
              id="feature-image" 
              src={tabs[0].image} 
              alt={tabs[0].title}
              class="w-full rounded border border-white/5 shadow-lg transition-opacity duration-500"
            />
            
            <!-- Simulated Scanning Line -->
            <div class="absolute top-0 left-0 w-full h-1 bg-primary shadow-[0_0_15px_#00D4AA] opacity-50 animate-[scan_3s_ease-in-out_infinite]"></div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  @keyframes scan {
    0% { top: 0%; opacity: 0; }
    10% { opacity: 0.5; }
    50% { opacity: 0.8; box-shadow: 0 0 20px #00D4AA; }
    90% { opacity: 0.5; }
    100% { top: 100%; opacity: 0; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.tab-btn');
    const image = document.getElementById('feature-image') as HTMLImageElement;
    const title = document.getElementById('console-title');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Reset all buttons
        buttons.forEach(b => {
          b.className = 'tab-btn text-left p-6 rounded-2xl border transition-all duration-300 relative overflow-hidden group bg-transparent border-white/10 hover:border-white/30 hover:bg-white/5';
          const titleEl = b.querySelector('h3');
          if (titleEl) titleEl.className = 'text-xl font-bold mb-2 transition-colors text-white group-hover:text-gray-200';
          
          // Handle indicator
          const indicator = b.querySelector('.active-indicator');
          if (indicator) {
            indicator.classList.remove('block');
            indicator.classList.add('hidden');
          }
        });

        // Set active button
        btn.className = 'tab-btn text-left p-6 rounded-2xl border transition-all duration-300 relative overflow-hidden group bg-primary/10 border-primary shadow-[0_0_20px_rgba(0,212,170,0.15)]';
        const activeTitleEl = btn.querySelector('h3');
        if (activeTitleEl) activeTitleEl.className = 'text-xl font-bold mb-2 transition-colors text-primary';
        
        // Add indicator dynamically or show existing
        let indicator = btn.querySelector('.active-indicator');
        if (!indicator) {
          indicator = document.createElement('div');
          indicator.className = 'absolute left-0 top-0 bottom-0 w-1 bg-primary active-indicator block';
          btn.prepend(indicator);
        } else {
          indicator.classList.remove('hidden');
          indicator.classList.add('block');
        }

        // Update image and title
        const newImage = btn.getAttribute('data-image');
        const newTitle = activeTitleEl?.textContent || '';
        
        if (image && newImage) {
          image.style.opacity = '0';
          setTimeout(() => {
            image.src = newImage;
            image.style.opacity = '1';
          }, 300);
        }
        
        if (title) {
          title.textContent = newTitle.trim();
        }
      });
    });
  });
</script>
