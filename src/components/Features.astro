---
import Container from "./Container.astro";

const tabs = [
  {
    id: "inventory",
    number: "01",
    label: "Inventory",
    title: "Agent 资产发现",
    description: "统一盘点桌面端与 CLI Agent。",
    image: "/assets/dashboard.png",
    imagePosition: "center top",
    chipStyle: "background: rgba(27, 97, 201, 0.1); color: var(--color-primary);",
  },
  {
    id: "supply-chain",
    number: "02",
    label: "MCP Audit",
    title: "Skills 安全扫描",
    description: "识别第三方能力的风险面。",
    image: "/assets/skills-management.png",
    imagePosition: "center top",
    chipStyle: "background: rgba(122, 61, 255, 0.12); color: var(--color-purple);",
  },
  {
    id: "runtime",
    number: "03",
    label: "Runtime Policy",
    title: "运行时防护",
    description: "在动作发生前做策略裁决。",
    image: "/assets/activity-monitor.png",
    imagePosition: "center top",
    chipStyle: "background: rgba(0, 100, 0, 0.1); color: var(--color-green);",
  },
  {
    id: "permissions",
    number: "04",
    label: "Access Control",
    title: "权限治理",
    description: "让最小权限真正执行。",
    image: "/assets/quarantine-zone.png",
    imagePosition: "center top",
    chipStyle: "background: rgba(255, 107, 0, 0.12); color: var(--color-orange);",
  },
  {
    id: "audit",
    number: "05",
    label: "Audit Trail",
    title: "审计与合规",
    description: "把每次决策都留下证据。",
    image: "/assets/risk-analysis.png",
    imagePosition: "center top",
    chipStyle: "background: rgba(237, 82, 203, 0.12); color: var(--color-pink);",
  },
];
---

<section id="features" class="relative py-16 lg:py-18">
  <Container>
    <div class="grid gap-4 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)] lg:items-end">
      <div>
        <div class="eyebrow">Product Layers</div>
        <h2 class="section-title mt-4">五项核心能力</h2>
      </div>
      <p class="section-copy max-w-xl lg:justify-self-end">
        先盘点，再扫描，再执行策略。
      </p>
    </div>

    <div class="mt-8 grid gap-4 xl:grid-cols-[286px_minmax(0,1fr)] xl:items-stretch">
      <div class="grid gap-2 content-start" id="features-tabs">
        {
          tabs.map((tab, index) => (
            <button
              class:list={["feature-tab", index === 0 && "is-active"]}
              data-feature-tab
              data-image={tab.image}
              data-title={tab.title}
              data-image-position={tab.imagePosition}
            >
              <div class="feature-tab-top">
                <div class="feature-tab-meta">{tab.number}</div>
                <span class="feature-tab-chip" style={tab.chipStyle}>{tab.label}</span>
              </div>
              <h3 class="mt-2.5 font-display text-[1rem] font-medium leading-[1.18] tracking-[0.08px]">
                {tab.title}
              </h3>
              <p class="mt-1 text-[12px] leading-[1.45]">{tab.description}</p>
            </button>
          ))
        }
      </div>

      <div id="feature-preview-card" class="surface-card overflow-hidden p-4 sm:p-5 lg:p-6 xl:h-full">
        <div class="surface-panel relative flex h-full min-h-0 flex-col overflow-hidden p-4 sm:p-5">
          <div class="mb-4 flex items-center justify-between border-b border-[var(--color-border)] pb-3">
            <div class="flex gap-2">
              <span class="h-3 w-3 rounded-full bg-[var(--color-red)]"></span>
              <span class="h-3 w-3 rounded-full bg-[var(--color-yellow)]"></span>
              <span class="h-3 w-3 rounded-full bg-[var(--color-green)]"></span>
            </div>
            <div id="feature-console-title" class="text-[11px] font-semibold uppercase tracking-[0.9px] text-[var(--color-gray-300)]">
              {tabs[0].title}
            </div>
          </div>

          <div class="feature-preview-stage overflow-hidden rounded-[18px] border border-[var(--color-border)] bg-white">
            <img
              id="feature-image"
              src={tabs[0].image}
              alt={tabs[0].title}
              class="feature-image"
              style={`--feature-image-position: ${tabs[0].imagePosition};`}
            />
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .feature-tab {
    border: 1px solid var(--color-border);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.78);
    min-height: 84px;
    padding: 14px 16px;
    text-align: left;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .feature-tab:hover {
    transform: translateY(-1px);
    border-color: rgba(27, 97, 201, 0.22);
    background: rgba(249, 252, 255, 0.97);
  }

  .feature-tab.is-active {
    border-color: var(--color-primary);
    background: rgba(27, 97, 201, 0.08);
    box-shadow: var(--theme_shadow-soft);
  }

  .feature-tab,
  .feature-tab p {
    color: var(--color-gray-500);
  }

  .feature-tab h3 {
    color: var(--color-ink);
  }

  .feature-tab-meta {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--color-gray-300);
  }

  .feature-tab-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .feature-tab-chip {
    display: none;
    min-height: 26px;
    align-items: center;
    border-radius: 999px;
    padding: 0 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.7px;
    text-transform: uppercase;
  }

  .feature-tab.is-active .feature-tab-chip {
    display: inline-flex;
  }

  .feature-preview-stage {
    flex: 1 1 auto;
    min-height: 0;
    padding: 8px;
    background:
      radial-gradient(circle at 50% 10%, rgba(27, 97, 201, 0.04), transparent 34%),
      linear-gradient(180deg, rgba(249, 252, 255, 0.88) 0%, rgba(255, 255, 255, 1) 100%);
  }

  .feature-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--feature-image-position, center top);
    transition: opacity 0.2s ease;
  }

  @media (max-width: 1279px) {
    .feature-preview-stage {
      height: 400px;
      min-height: 400px;
    }
  }

  @media (max-width: 767px) {
    .feature-tab {
      min-height: 78px;
      padding: 12px 14px;
    }

    .feature-preview-stage {
      height: 280px;
      min-height: 280px;
      padding: 6px;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const buttons = Array.from(document.querySelectorAll("[data-feature-tab]"));
    const image = document.getElementById("feature-image") as HTMLImageElement | null;
    const consoleTitle = document.getElementById("feature-console-title");
    const tabsColumn = document.getElementById("features-tabs");
    const previewCard = document.getElementById("feature-preview-card") as HTMLDivElement | null;

    const syncFeatureHeights = () => {
      if (!previewCard || !tabsColumn) return;

      if (window.innerWidth < 1280) {
        previewCard.style.height = "";
        return;
      }

      previewCard.style.height = `${tabsColumn.offsetHeight}px`;
    };

    const setActive = (button: Element) => {
      buttons.forEach((entry) => entry.classList.remove("is-active"));
      button.classList.add("is-active");

      const nextImage = button.getAttribute("data-image");
      const nextTitle = button.getAttribute("data-title") ?? "";
      const nextImagePosition = button.getAttribute("data-image-position") ?? "center top";

      if (consoleTitle) consoleTitle.textContent = nextTitle;

      if (image && nextImage) {
        image.style.opacity = "0";
        window.setTimeout(() => {
          image.src = nextImage;
          image.alt = nextTitle;
          image.style.setProperty("--feature-image-position", nextImagePosition);
          image.style.opacity = "1";
        }, 160);
      }

      window.requestAnimationFrame(syncFeatureHeights);
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => setActive(button));
    });

    window.addEventListener("resize", syncFeatureHeights);
    window.requestAnimationFrame(syncFeatureHeights);
  });
</script>
