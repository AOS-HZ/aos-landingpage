---
import Container from "./Container.astro";
import Link from "./ui/Link.astro";
---

<Container>
  <section id="launch" class="mt-32 md:mt-40 mb-10">
    <div class="relative mx-auto max-w-5xl overflow-hidden rounded-[2.5rem] bg-white px-8 py-16 text-center md:px-20 md:py-24 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] border border-slate-200/60 flex flex-col items-center">
      <!-- Glow effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-white to-indigo-50/50"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 h-[300px] w-[600px] bg-blue-400/20 blur-[100px] rounded-full pointer-events-none"></div>
      <div class="absolute inset-0 rounded-[2.5rem] ring-1 ring-inset ring-slate-900/5"></div>
      
      <div class="relative z-10 w-full max-w-3xl">
        <h2 class="font-display text-4xl font-bold tracking-tight text-slate-900 md:text-5xl lg:text-6xl">
          Ready to secure your local agents?
        </h2>
        <p class="mx-auto mt-6 text-lg text-slate-600 md:text-xl leading-relaxed">
          AOS 现已包含发现、分析和监控功能。将桌面安全防御真正落地。
        </p>
        <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row sm:items-center">
          <Link href="#hero" class="flex items-center justify-center shadow-lg shadow-blue-500/20 hover:shadow-blue-500/30 hover:-translate-y-0.5 transition-all w-full sm:w-auto">
            Get Started
          </Link>
          <Link
            style="outline"
            href="#"
            class="flex items-center justify-center bg-white/50 backdrop-blur-sm hover:bg-white/80 transition-all border-slate-200 hover:border-slate-300 w-full sm:w-auto"
          >
            View Documentation
          </Link>
        </div>
      </div>
    </div>
  </section>
</Container>
