---
import Container from "./Container.astro";
import Link from "./ui/Link.astro";
---

<section id="cta" class="py-32 relative overflow-hidden mt-10">
  <!-- Dynamic Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0e27] via-[#0F172A] to-primary/20"></div>
  
  <!-- Glowing orbs -->
  <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-96 h-96 bg-primary/20 rounded-full blur-[120px] animate-pulse-slow"></div>
  <div class="absolute top-1/2 right-1/4 -translate-y-1/2 w-96 h-96 bg-secondary/20 rounded-full blur-[120px] animate-pulse-slow" style="animation-delay: 2s;"></div>
  
  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 bg-[url('/assets/grid-pattern.svg')] opacity-10 mix-blend-overlay"></div>

  <Container>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-6xl font-display font-extrabold text-white mb-6 tracking-tight">
        为每一个智能体 <span class="text-gradient">保驾护航</span>
      </h2>
      
      <p class="text-xl text-text-muted mb-12 max-w-2xl mx-auto leading-relaxed">
        AgentOfShield 客户端现已提供免费下载体验。将桌面安全防御真正落地。
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 mb-12">
        <Link href="#download" style="primary" size="lg" class="w-full sm:w-auto text-lg px-8 py-4">
          立即下载客户端
        </Link>
        <Link href="https://docs.agentshield.site" style="outline" size="lg" class="w-full sm:w-auto text-lg px-8 py-4">
          查看使用文档
        </Link>
      </div>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-12 text-sm text-text-muted font-medium">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          SOC2 Type II 认证
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          GDPR 合规
        </div>
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          7×24 技术支持
        </div>
      </div>
    </div>
  </Container>
</section>
