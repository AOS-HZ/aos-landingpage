---
import Container from "./Container.astro";
---

<section id="cta" class="relative py-20 lg:py-24">
  <Container>
    <div class="rounded-[34px] border border-[rgba(24,29,38,0.08)] bg-white px-6 py-10 shadow-[0_24px_60px_rgba(15,23,42,0.04)] sm:px-8 lg:px-14 lg:py-12">
      <div class="max-w-[760px]">
        <h2 class="font-display text-[clamp(2rem,3.8vw,3.2rem)] font-medium leading-[1.04] tracking-[-0.045em] text-[var(--color-ink)]">
          从桌面端开始
        </h2>
        <p class="mt-4 max-w-[34rem] text-[1rem] leading-7 tracking-[0.01em] text-[var(--color-gray-500)] sm:text-[1.0625rem]">
          先接入环境，快速完成首轮扫描。
        </p>
      </div>
    </div>
  </Container>
</section>
