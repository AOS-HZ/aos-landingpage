---
import Container from "./Container.astro";
import Link from "./ui/Link.astro";
---

<Container>
  <section id="launch" class="mt-32 md:mt-40 mb-10">
    <div class="relative mx-auto max-w-5xl overflow-hidden rounded-[2.5rem] bg-slate-950 px-8 py-16 text-center md:px-20 md:py-24 shadow-2xl flex flex-col items-center">
      <!-- Glow effects -->
      <div class="absolute inset-0 bg-gradient-to-br from-blue-900/20 via-slate-950 to-indigo-900/20"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 h-[300px] w-[600px] bg-blue-500/20 blur-[100px] rounded-full pointer-events-none"></div>
      <div class="absolute inset-0 rounded-[2.5rem] ring-1 ring-inset ring-white/10"></div>
      
      <div class="relative z-10 w-full max-w-3xl">
        <h2 class="font-display text-4xl font-bold tracking-tight text-white md:text-5xl lg:text-6xl">
          Ready to secure your local agents?
        </h2>
        <p class="mx-auto mt-6 text-lg text-slate-300 md:text-xl leading-relaxed">
          AOS 现已包含发现、分析和监控功能。将桌面安全防御真正落地。
        </p>
        <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row">
          <Link href="#hero" style="inverted" class="shadow-lg shadow-white/5 hover:bg-slate-100 hover:scale-105 transition-all w-full sm:w-auto">
            Get Started
          </Link>
          <a href="#" class="rounded-full px-5 py-2.5 font-mono text-xs uppercase tracking-[0.16em] text-white border border-white/20 hover:bg-white/10 transition-colors flex items-center justify-center w-full sm:w-auto">
            View Documentation
          </a>
        </div>
      </div>
    </div>
  </section>
</Container>
